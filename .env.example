# Copy to .env and adjust. .env is gitignored.
MSSQL_SA_PASSWORD=Your_Strong_P@ssw0rd1
JWT_KEY=replace-with-a-long-random-32+char-secret-key-please
JWT_ISSUER=EncryptedChat
JWT_AUDIENCE=EncryptedChat.Client
# Optionnel : clé API Giphy pour le picker GIF (vide => endpoints GIF en erreur, le reste marche).
GIPHY_API_KEY=
# Clé AES-256 (base64, 32 octets) pour le chiffrement au repos des champs sensibles.
# Générer : openssl rand -base64 32
ENCRYPTION_KEY=
