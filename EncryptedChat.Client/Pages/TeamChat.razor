@page "/Team/{TeamId:guid}"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.SignalR.Client
@using EncryptedChat.Client.Services

@inject AuthenticationStateProvider AuthStateProvider
@inject TeamClient TeamClient
@inject ChatClient ChatClient
@inject AttachmentClient AttachmentClient
@inject FriendClient FriendClient
@inject AuthClient AuthClient
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS

@implements IAsyncDisposable

<section>
    <div class="relative grid place-items-center px-6 py-10 mx-auto min-h-[60svh] md:min-h-[65svh] lg:min-h-[70svh]">
        <div class="flex flex-col items-center w-full sm:max-w-2xl md:mt-0">
            <div class="liquid-glass-wrapper rounded-3xl shadow-2xl w-full"
                style="border-radius: 20px; background-color: rgba(255, 255, 255, 0.05); box-shadow: rgba(0, 0, 0, 0.2) 0px 6px 6px, rgba(0, 0, 0, 0.1) 0px 0px 20px;">

                <div class="liquid-glass-effect" aria-hidden="true"></div>
                <div class="liquid-glass-tint" aria-hidden="true"></div>
                <div class="liquid-glass-shine" aria-hidden="true"></div>

                <div class="liquid-glass-content p-6 space-y-4 md:space-y-6 sm:p-8">
                    <!-- Header -->
                    <div class="flex items-center justify-between">
                        <button type="button" class="text-gray-400 hover:text-white transition cursor-pointer"
                            @onclick="GoBack">
                            &larr; Back
                        </button>
                        <h1 class="text-xl font-bold text-white">
                            @(teamDetails?.Name ?? "Loading...")
                        </h1>
                        @if (isAdmin)
                        {
                            <button type="button"
                                class="text-xs px-2 py-1 rounded bg-white/10 hover:bg-white/20 text-gray-300 transition cursor-pointer"
                                @onclick="OpenMemberModal">
                                Members
                            </button>
                        }
                        else
                        {
                            <div></div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <p class="text-sm text-red-400">@errorMessage</p>
                    }

                    <!-- Messages -->
                    <div id="messages-container" class="space-y-2 pr-1 bg-black/30 rounded-xl p-4 border border-white/5"
                         style="max-height: 50vh; min-height: 20vh; overflow-y: auto;">
                        @if (isLoadingMessages)
                        {
                            <p class="text-xs text-gray-400">Loading messages...</p>
                        }
                        else if (!messages.Any())
                        {
                            <p class="text-xs text-gray-400 italic text-center mt-20">No messages yet. Start the conversation!</p>
                        }
                        else
                        {
                            @foreach (var msg in messages)
                            {
                                <div class="text-sm text-gray-200 @(msg.Sender?.Id == _userId ? "text-right" : "")">
                                    <div class="@(msg.Sender?.Id == _userId ? "bg-blue-600/30" : "bg-white/10") inline-block rounded-lg px-3 py-2 max-w-[80%]">
                                        <div class="text-xs text-gray-400 mb-1">
                                            <span class="font-semibold text-gray-300">@msg.Sender?.Name</span>
                                            <span class="ml-2">@msg.Date.ToLocalTime().ToString("HH:mm")</span>
                                        </div>
                                        <div class="text-gray-100">@msg.Text</div>
                                        @if (msg.Attachments?.Any() == true)
                                        {
                                            <div class="mt-2 flex flex-wrap gap-2">
                                                @foreach (var att in msg.Attachments)
                                                {
                                                    @if (att.MimeType.StartsWith("image/"))
                                                    {
                                                        <a href="@GetAttachmentUrl(att.Id)" target="_blank" class="block max-w-[150px]">
                                                            <img src="@GetAttachmentUrl(att.Id)" alt="@att.FileName"
                                                                class="rounded-lg max-h-24 object-cover border border-white/10" />
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <a href="@GetAttachmentUrl(att.Id)" target="_blank"
                                                            class="flex items-center gap-1 px-2 py-1 bg-white/10 rounded text-xs text-blue-300 hover:bg-white/20">
                                                            <span>@att.FileName</span>
                                                            <span class="text-gray-400">(@FormatFileSize(att.Size))</span>
                                                        </a>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- File Preview -->
                    @if (selectedFiles.Any())
                    {
                        <div class="flex flex-wrap gap-2 p-2 bg-black/20 rounded-lg border border-white/10">
                            @foreach (var file in selectedFiles)
                            {
                                <div class="relative group">
                                    @if (file.PreviewUrl != null)
                                    {
                                        <img src="@file.PreviewUrl" alt="@file.Name"
                                            class="h-16 w-16 object-cover rounded-lg border border-white/10" />
                                    }
                                    else
                                    {
                                        <div class="h-16 w-16 flex items-center justify-center bg-white/10 rounded-lg border border-white/10">
                                            <span class="text-xs text-gray-300 text-center px-1 truncate">@file.Name</span>
                                        </div>
                                    }
                                    <button type="button"
                                        class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full text-white text-xs opacity-0 group-hover:opacity-100 transition cursor-pointer"
                                        @onclick="() => RemoveSelectedFile(file)">
                                        &times;
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    <!-- Message Input -->
                    <div class="flex gap-2">
                        <label class="cursor-pointer px-3 py-2 bg-white/10 rounded-lg hover:bg-white/20 transition">
                            <InputFile OnChange="OnFilesSelected" multiple accept="image/*,.pdf,.doc,.docx,.txt" class="hidden" />
                            <span class="text-gray-300">+</span>
                        </label>
                        <input type="text" placeholder="Type a message..."
                            class="flex-1 rounded-lg px-4 py-2 bg-black/40 border border-white/10 text-white"
                            @bind="newMessageText" @bind:event="oninput" @onkeydown="HandleKeyDown" disabled="@isSending" />
                        <button type="button"
                            class="glass-button-primary px-4 py-2 cursor-pointer"
                            @onclick="SendMessage" disabled="@isSending">
                            @(isSending ? "..." : "Send")
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(uploadError))
                    {
                        <p class="text-xs text-red-400">@uploadError</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Member Management Modal -->
    @if (isMemberModalOpen)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60">
            <div class="liquid-glass-wrapper rounded-3xl shadow-2xl w-full max-w-lg mx-4"
                style="border-radius: 20px; background-color: rgba(255, 255, 255, 0.05);">

                <div class="liquid-glass-effect" aria-hidden="true"></div>
                <div class="liquid-glass-tint" aria-hidden="true"></div>
                <div class="liquid-glass-shine" aria-hidden="true"></div>

                <div class="liquid-glass-content p-6 space-y-4 sm:p-8">
                    <div class="flex items-center justify-between mb-2">
                        <h2 class="text-lg font-semibold text-white">Manage Members</h2>
                        <button type="button" class="text-gray-400 hover:text-gray-200 cursor-pointer" @onclick="CloseMemberModal">
                            &times;
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(memberError))
                    {
                        <p class="text-sm text-red-400">@memberError</p>
                    }

                    <!-- Add Member (search friends) -->
                    <div class="space-y-2">
                        <label class="block text-sm font-medium text-gray-200">Add Friend to Team</label>
                        <input type="text" placeholder="Search your friends..."
                            class="w-full rounded-lg px-3 py-2 bg-black/40 border border-white/10 text-white text-sm"
                            @bind="memberSearchQuery" @bind:event="oninput" @onkeyup="HandleMemberSearchKeyUp" />

                        @if (friendSearchResults.Any())
                        {
                            <div class="max-h-32 overflow-y-auto bg-black/30 rounded-lg border border-white/10">
                                @foreach (var friend in friendSearchResults)
                                {
                                    <button type="button"
                                        class="w-full text-left px-3 py-2 hover:bg-white/10 text-sm text-gray-200 flex justify-between items-center cursor-pointer"
                                        @onclick="() => AddMember(friend.Id)">
                                        <span>@friend.Name</span>
                                        <span class="text-xs text-green-400">+ Add</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    <!-- Current Members -->
                    <div class="space-y-2">
                        <label class="block text-sm font-medium text-gray-200">Current Members</label>
                        @if (teamDetails?.Members == null || !teamDetails.Members.Any())
                        {
                            <p class="text-xs text-gray-400">No members found.</p>
                        }
                        else
                        {
                            <div class="max-h-48 overflow-y-auto space-y-1">
                                @foreach (var member in teamDetails.Members.OrderByDescending(m => m.Role == "Admin"))
                                {
                                    <div class="flex justify-between items-center px-3 py-2 bg-black/20 rounded-lg">
                                        <div>
                                            <span class="text-sm text-white">@member.User?.Name</span>
                                            <span class="ml-2 text-xs @(member.Role == "Admin" ? "text-yellow-400" : "text-blue-400")">
                                                @member.Role
                                            </span>
                                        </div>
                                        @if (member.User?.Id != _userId && member.Role != "Admin")
                                        {
                                            <div class="flex gap-2">
                                                <button type="button"
                                                    class="text-xs text-green-400 hover:text-green-300 cursor-pointer"
                                                    @onclick="() => PromoteMember(member.User!.Id)">
                                                    Promote
                                                </button>
                                                <button type="button"
                                                    class="text-xs text-red-400 hover:text-red-300 cursor-pointer"
                                                    @onclick="() => RemoveMember(member.User!.Id)">
                                                    Remove
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="flex justify-end mt-4">
                        <button type="button"
                            class="px-4 py-2 rounded-lg border border-white/10 bg-black/30 text-sm text-gray-200 cursor-pointer hover:bg-black/50"
                            @onclick="CloseMemberModal">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</section>

@code {
    [Parameter]
    public Guid TeamId { get; set; }

    private string? _userId;
    private string? errorMessage;
    private bool isAdmin;

    private TeamClient.TeamDetailDTO? teamDetails;
    private List<ChatClient.MessageDTOPublic> messages = new();
    private string newMessageText = string.Empty;
    private bool isLoadingMessages;
    private bool isSending;
    private string? uploadError;

    private HubConnection? hubConnection;

    // Member management
    private bool isMemberModalOpen;
    private string? memberError;
    private string memberSearchQuery = string.Empty;
    private List<FriendClient.UserDTO> friendSearchResults = new();
    private System.Timers.Timer? memberSearchDebounceTimer;

    // File upload
    private List<SelectedFile> selectedFiles = new();
    private const long MaxFileSize = 25 * 1024 * 1024;

    // Scroll control
    private bool _shouldScrollToBottom;

    private class SelectedFile
    {
        public string Name { get; set; } = string.Empty;
        public string ContentType { get; set; } = string.Empty;
        public long Size { get; set; }
        public IBrowserFile BrowserFile { get; set; } = null!;
        public string? PreviewUrl { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity is null || !user.Identity.IsAuthenticated)
        {
            Navigation.NavigateTo("/Login");
            return;
        }

        _userId = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;

        await LoadTeamDetails();
        await LoadMessagesAsync();
        await InitializeSignalR();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScrollToBottom)
        {
            _shouldScrollToBottom = false;
            await JS.InvokeVoidAsync("scrollToBottom", "messages-container");
        }
    }

    private async Task LoadTeamDetails()
    {
        var result = await TeamClient.GetTeamDetailsAsync(TeamId);
        if (result.Success && result.Value != null)
        {
            teamDetails = result.Value;
            isAdmin = teamDetails.Members?.Any(m => m.User?.Id == _userId && m.Role == "Admin") ?? false;
        }
        else
        {
            errorMessage = result.ErrorMessage ?? "Failed to load team.";
        }
    }

    private async Task InitializeSignalR()
    {
        try
        {
            var token = await AuthClient.GetSignalRTokenAsync();
            if (string.IsNullOrEmpty(token))
            {
                errorMessage = "Could not get SignalR token.";
                return;
            }

            hubConnection = new HubConnectionBuilder()
                .WithUrl($"https://localhost:7294/hubs/chat?access_token={token}")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<ChatClient.MessageDTOPublic>("ReceiveMessage", message =>
            {
                if (message.TeamId == TeamId)
                {
                    messages.Add(message);
                    _shouldScrollToBottom = true;
                    InvokeAsync(StateHasChanged);
                }
            });

            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("JoinTeam", TeamId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SignalR] Failed: {ex.Message}");
            errorMessage = "Chat connection could not be established.";
        }
    }

    private async Task LoadMessagesAsync()
    {
        isLoadingMessages = true;
        try
        {
            var result = await ChatClient.GetMessagesByTeamAsync(TeamId);
            if (result.Success)
            {
                messages = (result.Value ?? []).OrderBy(m => m.Date).ToList();
                _shouldScrollToBottom = true;
            }
            else
            {
                errorMessage = result.ErrorMessage;
            }
        }
        finally
        {
            isLoadingMessages = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isSending)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessageText) && !selectedFiles.Any())
            return;

        if (string.IsNullOrWhiteSpace(_userId))
            return;

        isSending = true;
        uploadError = null;

        try
        {
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                await hubConnection.InvokeAsync("SendMessageToTeam", TeamId, newMessageText ?? "");

                if (selectedFiles.Any())
                {
                    await Task.Delay(300);
                    var lastMessage = messages.LastOrDefault();
                    if (lastMessage != null)
                    {
                        foreach (var file in selectedFiles.ToList())
                        {
                            try
                            {
                                using var stream = file.BrowserFile.OpenReadStream(MaxFileSize);
                                using var ms = new MemoryStream();
                                await stream.CopyToAsync(ms);
                                ms.Position = 0;

                                await AttachmentClient.UploadAsync(lastMessage.Id, ms, file.Name, file.ContentType);
                            }
                            catch (Exception ex)
                            {
                                uploadError = $"Failed to upload {file.Name}: {ex.Message}";
                            }
                        }
                        selectedFiles.Clear();
                        await LoadMessagesAsync();
                    }
                }

                newMessageText = string.Empty;
            }
            else
            {
                errorMessage = "Not connected to chat.";
            }
        }
        finally
        {
            isSending = false;
        }
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(5))
        {
            if (file.Size > MaxFileSize)
            {
                uploadError = $"{file.Name} is too large. Max size is 25 MB.";
                continue;
            }

            var selectedFile = new SelectedFile
            {
                Name = file.Name,
                ContentType = file.ContentType,
                Size = file.Size,
                BrowserFile = file
            };

            if (file.ContentType.StartsWith("image/"))
            {
                try
                {
                    var resized = await file.RequestImageFileAsync(file.ContentType, 200, 200);
                    using var stream = resized.OpenReadStream(MaxFileSize);
                    using var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);
                    selectedFile.PreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
                }
                catch
                {
                    selectedFile.PreviewUrl = null;
                }
            }

            selectedFiles.Add(selectedFile);
        }
    }

    private void RemoveSelectedFile(SelectedFile file) => selectedFiles.Remove(file);

    private void GoBack() => Navigation.NavigateTo("/Team");

    private string GetAttachmentUrl(Guid attachmentId) =>
        $"https://localhost:7294/api/attachment/{attachmentId}/download";

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    // Member management
    private void OpenMemberModal()
    {
        isMemberModalOpen = true;
        memberError = null;
        memberSearchQuery = string.Empty;
        friendSearchResults.Clear();
    }

    private void CloseMemberModal()
    {
        isMemberModalOpen = false;
        friendSearchResults.Clear();
    }

    private void HandleMemberSearchKeyUp(KeyboardEventArgs e)
    {
        memberSearchDebounceTimer?.Stop();
        memberSearchDebounceTimer?.Dispose();

        memberSearchDebounceTimer = new System.Timers.Timer(300);
        memberSearchDebounceTimer.Elapsed += async (s, args) =>
        {
            memberSearchDebounceTimer?.Stop();
            await InvokeAsync(async () =>
            {
                await SearchFriends();
                StateHasChanged();
            });
        };
        memberSearchDebounceTimer.AutoReset = false;
        memberSearchDebounceTimer.Start();
    }

    private async Task SearchFriends()
    {
        if (string.IsNullOrWhiteSpace(memberSearchQuery) || memberSearchQuery.Length < 2)
        {
            friendSearchResults.Clear();
            return;
        }

        var result = await FriendClient.SearchFriendsAsync(memberSearchQuery);
        if (result.Success && result.Value != null)
        {
            var existingMemberIds = teamDetails?.Members?
                .Where(m => m.User != null)
                .Select(m => m.User!.Id)
                .ToHashSet() ?? new HashSet<string>();

            friendSearchResults = result.Value
                .Where(f => !existingMemberIds.Contains(f.Id))
                .ToList();
        }
        else
        {
            friendSearchResults.Clear();
        }
    }

    private async Task AddMember(string userId)
    {
        memberError = null;
        var result = await TeamClient.AddMemberAsync(TeamId, userId);

        if (result.Success)
        {
            memberSearchQuery = string.Empty;
            friendSearchResults.Clear();
            await LoadTeamDetails();
        }
        else
        {
            memberError = result.ErrorMessage ?? "Failed to add member. Make sure they are your friend.";
        }
    }

    private async Task RemoveMember(string userId)
    {
        memberError = null;
        var result = await TeamClient.RemoveMemberAsync(TeamId, userId);

        if (result.Success)
        {
            await LoadTeamDetails();
        }
        else
        {
            memberError = result.ErrorMessage;
        }
    }

    private async Task PromoteMember(string userId)
    {
        memberError = null;
        var result = await TeamClient.PromoteToAdminAsync(TeamId, userId);

        if (result.Success)
        {
            await LoadTeamDetails();
        }
        else
        {
            memberError = result.ErrorMessage;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            try
            {
                await hubConnection.InvokeAsync("LeaveTeam", TeamId);
                await hubConnection.DisposeAsync();
            }
            catch { }
        }
    }
}
