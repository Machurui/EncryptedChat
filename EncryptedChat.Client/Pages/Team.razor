@page "/Team"
@attribute [Authorize]

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using EncryptedChat.Client.Services

@inject AuthenticationStateProvider AuthStateProvider
@inject TeamClient TeamClient
@inject NavigationManager Navigation

<section>
    <div class="relative grid place-items-center px-6 py-10 mx-auto min-h-[60svh] md:min-h-[65svh] lg:min-h-[70svh]">
        <div class="flex flex-col items-center w-full sm:max-w-md md:mt-0">
            <div class="liquid-glass-wrapper rounded-3xl shadow-2xl w-full"
                style="border-radius: 20px; background-color: rgba(255, 255, 255, 0.05); box-shadow: rgba(0, 0, 0, 0.2) 0px 6px 6px, rgba(0, 0, 0, 0.1) 0px 0px 20px;">

                <div class="liquid-glass-effect" aria-hidden="true"></div>
                <div class="liquid-glass-tint" aria-hidden="true"></div>
                <div class="liquid-glass-shine" aria-hidden="true"></div>

                <div class="liquid-glass-content p-6 space-y-4 md:space-y-6 sm:p-8">
                    <h1 class="flex justify-center text-xl font-bold leading-tight tracking-tight text-white md:text-2xl">
                        My Teams
                    </h1>

                    <button type="button" class="glass-button-primary w-full justify-center cursor-pointer"
                        @onclick="OpenNewTeamModal">
                        <span>+ New Team</span>
                    </button>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <p class="text-sm text-red-400">@errorMessage</p>
                    }

                    <!-- Teams list -->
                    <div class="mt-4 space-y-3 pr-1" style="max-height: 50vh; overflow-y: auto;">
                        @if (isLoading)
                        {
                            <p class="text-sm text-gray-300 text-center">Loading...</p>
                        }
                        else if (!teams.Any())
                        {
                            <p class="text-sm text-gray-300 text-center">
                                No teams yet. Click "New Team" to create one.
                            </p>
                        }
                        else
                        {
                            @foreach (var team in teams)
                            {
                                <button type="button"
                                    class="w-full text-left rounded-xl p-4 bg-black/20 border border-white/5 hover:bg-white/10 transition group cursor-pointer"
                                    @onclick="() => OpenTeam(team.Id)">
                                    <div class="flex justify-between items-center">
                                        <div>
                                            <h2 class="font-semibold text-white group-hover:text-blue-300 transition">
                                                @team.Name
                                            </h2>
                                            <p class="text-xs text-gray-400 mt-1">
                                                <span class="@(team.Role == "Admin" ? "text-yellow-400" : "text-gray-400")">
                                                    @team.Role
                                                </span>
                                            </p>
                                        </div>
                                        <span class="text-gray-500 group-hover:text-white transition">&rarr;</span>
                                    </div>
                                </button>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- New Team Modal -->
    @if (isNewTeamModalOpen)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60">
            <div class="liquid-glass-wrapper rounded-3xl shadow-2xl w-full max-w-lg mx-4"
                style="border-radius: 20px; background-color: rgba(255, 255, 255, 0.05);">

                <div class="liquid-glass-effect" aria-hidden="true"></div>
                <div class="liquid-glass-tint" aria-hidden="true"></div>
                <div class="liquid-glass-shine" aria-hidden="true"></div>

                <div class="liquid-glass-content p-6 space-y-4 sm:p-8">
                    <div class="flex items-center justify-between mb-2">
                        <h2 class="text-lg font-semibold text-white">Create New Team</h2>
                        <button type="button" class="text-gray-400 hover:text-gray-200 cursor-pointer" @onclick="CloseNewTeamModal">
                            &times;
                        </button>
                    </div>

                    <EditForm Model="@teamModel" OnValidSubmit="@HandleNewTeam">
                        <DataAnnotationsValidator />

                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-200 mb-1">Team Name</label>
                                <InputText class="w-full rounded-lg px-3 py-2 bg-black/40 border border-white/10 text-white"
                                    @bind-Value="teamModel.Name" />
                                <ValidationMessage For="() => teamModel.Name" class="text-xs text-red-400" />
                            </div>

                            <div class="flex justify-end gap-3 mt-4">
                                <button type="button"
                                    class="px-4 py-2 rounded-lg border border-white/10 bg-black/30 text-sm text-gray-200 cursor-pointer hover:bg-black/50"
                                    @onclick="CloseNewTeamModal" disabled="@isSubmitting">
                                    Cancel
                                </button>
                                <button type="submit" class="glass-button-primary px-4 py-2 text-sm cursor-pointer"
                                    disabled="@isSubmitting">
                                    @(isSubmitting ? "Creating..." : "Create Team")
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }
</section>

@code {
    private string? _userId;
    private string? errorMessage;
    private bool isLoading;
    private bool isNewTeamModalOpen;
    private bool isSubmitting;

    private List<TeamClient.TeamDTOPublic> teams = new();
    private TeamModel teamModel = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity is null || !user.Identity.IsAuthenticated)
        {
            Navigation.NavigateTo("/Login");
            return;
        }

        _userId = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(_userId))
        {
            errorMessage = "Could not determine your user id.";
            return;
        }

        await LoadTeamsAsync();
    }

    private async Task LoadTeamsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await TeamClient.GetTeamsByUserAsync(_userId!);
            if (result.Success)
            {
                teams = result.Value ?? [];
            }
            else
            {
                errorMessage = result.ErrorMessage;
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenTeam(Guid teamId)
    {
        Navigation.NavigateTo($"/Team/{teamId}");
    }

    private void OpenNewTeamModal()
    {
        errorMessage = null;
        teamModel = new TeamModel();
        isNewTeamModalOpen = true;
    }

    private void CloseNewTeamModal()
    {
        isNewTeamModalOpen = false;
    }

    private async Task HandleNewTeam()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(teamModel.Name))
        {
            errorMessage = "Team name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_userId))
        {
            errorMessage = "User id is missing.";
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await TeamClient.AddTeamAsync(new[] { _userId }, Array.Empty<string>(), teamModel.Name);

            if (!result.Success)
            {
                errorMessage = result.ErrorMessage;
                return;
            }

            isNewTeamModalOpen = false;
            teamModel = new TeamModel();
            await LoadTeamsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class TeamModel
    {
        [Required(ErrorMessage = "Team name is required")]
        [StringLength(100, MinimumLength = 1, ErrorMessage = "Name must be 1-100 characters")]
        public string Name { get; set; } = string.Empty;
    }
}
