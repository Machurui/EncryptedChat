    .friends-title {
        font-size: 14px;
        font-weight: 700;
        color: white;
        letter-spacing: -0.01em;
    }

    .friends-stats {
        font-size: 10.5px;
        color: rgba(255,255,255,0.55);
        margin-top: 2px;
    }

    .friends-search {
        padding: 0 14px 10px;
    }

    .friends-tabs {
        display: flex;
        gap: 4px;
        padding: 0 14px 10px;
    }

    .friends-tab {
        flex: 1;
        padding: 6px 0;
        border-radius: 8px;
        font-size: 11.5px;
        font-weight: 600;
        background: transparent;
        border: 0.5px solid rgba(255,255,255,0.10);
        color: rgba(255,255,255,0.65);
        cursor: pointer;
        font-family: inherit;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        transition: all 0.15s;
    }

    .friends-tab:hover {
        background: rgba(255,255,255,0.06);
    }

    .friends-tab.active {
        background: rgba(255,255,255,0.12);
        border-color: rgba(255,255,255,0.18);
        color: white;
    }

    .tab-badge {
        font-size: 9px;
        font-weight: 700;
        padding: 0 5px;
        border-radius: 999px;
        background: var(--accent);
        color: white;
        min-width: 14px;
        text-align: center;
    }

    .friends-content {
        flex: 1;
        overflow: auto;
        padding: 0 10px 14px;
    }

    .section-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.45);
        padding: 4px 12px 6px;
    }

    .friend-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 12px;
        margin-bottom: 1px;
        cursor: pointer;
        transition: background 0.15s;
    }

    .friend-row:hover {
        background: rgba(255,255,255,0.06);
    }

    .friend-info {
        flex: 1;
        min-width: 0;
    }

    .friend-name {
        font-size: 12.5px;
        font-weight: 600;
        color: white;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .friend-status {
        font-size: 10px;
        color: rgba(255,255,255,0.55);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(255,255,255,0.30);
    }

    .status-dot.online {
        background: var(--status-online);
        box-shadow: 0 0 6px var(--status-online);
