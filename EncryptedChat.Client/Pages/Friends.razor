@page "/friends"
@layout EmptyLayout
@attribute [Authorize]
@implements IAsyncDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using EncryptedChat.Client.Services
@using EncryptedChat.Client.Pages.Components

@inject AuthenticationStateProvider AuthStateProvider
@inject AuthClient AuthClient
@inject FriendClient FriendClient
@inject NavigationManager Navigation

<div class="app-background"></div>

<div class="friends-page">
    <GlassPanel Radius="24" Class="friends-page-panel" Style="width: 100%; max-width: 480px; height: 100%; max-height: 640px; display: flex; flex-direction: column;">
        <!-- Header -->
        <div class="friends-header">
            <div class="friends-header-left">
                <a href="/chat" class="back-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                    </svg>
                </a>
                <div>
                    <div class="friends-title">Friends</div>
                    <div class="friends-stats">@friends.Count total · @friends.Count(f => f.Status == "online") online</div>
                </div>
            </div>
            <IconButton Title="Add friend" OnClick="() => showAddModal = true">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
            </IconButton>
        </div>

        <!-- Search -->
        <div class="friends-search">
            <GlassInput @bind-Value="searchQuery" Placeholder="Search friends..." Style="background: rgba(0,0,0,0.18);">
                <Icon>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                </Icon>
            </GlassInput>
        </div>

        <!-- Tabs -->
        <div class="friends-tabs">
            <button class="friends-tab @(activeTab == "all" ? "active" : "")" @onclick='() => activeTab = "all"'>
                All
            </button>
            <button class="friends-tab @(activeTab == "online" ? "active" : "")" @onclick='() => activeTab = "online"'>
                Online
            </button>
            <button class="friends-tab @(activeTab == "requests" ? "active" : "")" @onclick='() => activeTab = "requests"'>
                Requests
                @if (incomingRequests.Any())
                {
                    <span class="tab-badge">@incomingRequests.Count</span>
                }
            </button>
        </div>

        <!-- Content -->
        <div class="friends-content">
            @if (isLoading)
            {
                <div aria-busy="true">
                    @for (int i = 0; i < 5; i++)
                    {
                        <SkeletonFriendRow />
                    }
                </div>
            }
            else if (activeTab == "requests")
            {
                @if (incomingRequests.Any())
                {
                    <div class="section-label">Incoming · @incomingRequests.Count</div>
                    @foreach (var req in incomingRequests)
                    {
                        <div class="request-card">
                            <div class="request-header">
                                <Avatar Name="@req.Name" Size="32" />
                                <div class="request-info">
                                    <div class="request-name">@req.Name</div>
                                    <div class="request-meta">
                                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 006 0v-1a10 10 0 10-3.92 7.94"/>
                                        </svg>
                                        by handle
                                    </div>
                                </div>
                            </div>
                            <div class="request-actions">
                                <GlassButton Primary="true" Size="sm" Style="flex: 1;" OnClick="() => AcceptRequest(req.RequestId)">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Accept
                                </GlassButton>
                                <GlassButton Size="sm" Style="flex: 1;" OnClick="() => RejectRequest(req.RequestId)">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;">
                                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                                    </svg>
                                    Decline
                                </GlassButton>
                            </div>
                        </div>
                    }
                }

                @if (outgoingRequests.Any())
                {
                    <div class="section-label" style="margin-top: 14px;">Sent · @outgoingRequests.Count</div>
                    @foreach (var req in outgoingRequests)
                    {
                        <div class="sent-request">
                            <Avatar Name="@req.Name" Size="28" />
                            <div class="sent-info">
                                <div class="sent-name">@req.Name</div>
                                <div class="sent-status">Pending</div>
                            </div>
                            <GlassButton Size="sm" OnClick="() => CancelRequest(req.RequestId)">Cancel</GlassButton>
                        </div>
                    }
                }

                @if (!incomingRequests.Any() && !outgoingRequests.Any())
                {
                    <div class="empty-state">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                            <circle cx="8.5" cy="7" r="4"/>
                            <line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
                        </svg>
                        <div class="empty-title">No pending requests</div>
                        <div class="empty-desc">Friend requests will appear here</div>
                    </div>
                }
            }
            else
            {
                @foreach (var friend in filteredFriends)
                {
                    <div class="friend-row">
                        <Avatar Name="@friend.Name" Size="32" />
                        <div class="friend-info">
                            <div class="friend-name">@friend.Name</div>
                            <div class="friend-status">
                                <span class="status-dot @GetDisplayStatus(friend.Status)"></span>
                                @if (!string.IsNullOrEmpty(friend.StatusMessage))
                                {
                                    @friend.StatusMessage
                                }
                                else
                                {
                                    @GetStatusLabel(friend.Status)
                                }
                            </div>
                        </div>
                        <IconButton Title="Message" Size="28">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                        </IconButton>
                        <IconButton Title="Safety number" Size="28" OnClick="() => OpenSafety(friend.UserId, friend.Name)">
                            🔒
                        </IconButton>
                        <IconButton Title="Remove" Size="28" OnClick="() => RemoveFriend(friend.UserId)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>
                            </svg>
                        </IconButton>
                    </div>
                }

                @if (!filteredFriends.Any())
                {
                    <div class="empty-state">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87m-4-12a4 4 0 010 7.75"/>
                        </svg>
                        <div class="empty-title">@(activeTab == "online" ? "No friends online" : "No friends yet")</div>
                        <div class="empty-desc">@(activeTab == "online" ? "Your online friends will appear here" : "Add friends to start chatting")</div>
                    </div>
                }
            }
        </div>
    </GlassPanel>
</div>

<AddFriendModal IsOpen="@showAddModal" OnClose="() => showAddModal = false" OnRequestSent="HandleRequestSent" />

<SafetyNumberPanel IsOpen="_showSafety" UserId="_safetyUserId" DisplayName="_safetyName"
                   OnClose="() => _showSafety = false" />

<style>
    .friends-page {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
    }

    .friends-header {
        padding: 18px 18px 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .friends-header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .back-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 10px;
        color: rgba(255,255,255,0.60);
        text-decoration: none;
        transition: all 0.15s;
