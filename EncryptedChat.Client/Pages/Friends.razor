    .request-card {
        padding: 10px 12px;
        border-radius: 14px;
        margin-bottom: 6px;
        background: rgba(255,255,255,0.05);
        border: 0.5px solid rgba(255,255,255,0.10);
    }

    .request-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 8px;
    }

    .request-info {
        flex: 1;
        min-width: 0;
    }

    .request-name {
        font-size: 12.5px;
        font-weight: 600;
        color: white;
    }

    .request-meta {
        font-size: 10px;
        color: rgba(255,255,255,0.55);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .request-actions {
        display: flex;
        gap: 6px;
    }

    .sent-request {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 12px;
