</style>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public TeamClient.TeamDTOPublic? Team { get; set; }
    [Parameter] public List<TeamClient.MemberDTOPublic>? Members { get; set; }
    [Parameter] public List<FriendClient.FriendDTO>? Friends { get; set; }
    [Parameter] public string? CurrentUserId { get; set; }
    [Parameter] public bool IsAdmin { get; set; }
    [Parameter] public bool IsOwner { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnPromote { get; set; }
    [Parameter] public EventCallback<string> OnDemote { get; set; }
    [Parameter] public EventCallback<string> OnRemove { get; set; }
    [Parameter] public EventCallback<string> OnRename { get; set; }
    [Parameter] public EventCallback<string> OnAddMember { get; set; }
    [Parameter] public EventCallback<string> OnTransferOwnership { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    // Bubble color (per-user). Parent owns the source-of-truth dict
    // (userBubbleColors[teamId]); the modal reads via MyBubbleColor and
    // writes via OnBubbleColorChange(color) / OnBubbleColorReset().
    [Parameter] public string? MyBubbleColor { get; set; }
    [Parameter] public EventCallback<string> OnBubbleColorChange { get; set; }
    [Parameter] public EventCallback OnBubbleColorReset { get; set; }

    private const string ApiBaseUrl = "https://localhost:7294";
    private const string DefaultBubbleColor = "oklch(0.65 0.16 165)";

    private string activeTab = "general";
    private string editTeamName = "";
    private string inviteQuery = "";
    private bool isSaving;
    private bool isInviting;
    private bool isDeleting;
    private bool showDeleteConfirm;
    private string deleteConfirmText = "";
    private string? transferTargetId;
    private bool isTransferring;
    private string? errorMessage;

    private Guid? _lastTeamId;

    protected override void OnParametersSet()
    {
        if (Team == null) return;

        // Reset edit state when switching teams so half-edits don't leak.
        if (_lastTeamId != Team.Id)
        {
            _lastTeamId = Team.Id;
            editTeamName = Team.Name;
            return;
        }

        if (!isSaving && (string.IsNullOrEmpty(editTeamName) || editTeamName == Team.Name))
            editTeamName = Team.Name;
    }

    private bool RenameChanged =>
        !string.IsNullOrWhiteSpace(editTeamName)
        && editTeamName.Trim() != Team?.Name
        && editTeamName.Length <= 100;

    private string CurrentBubbleColor => MyBubbleColor ?? DefaultBubbleColor;

    private IEnumerable<FriendClient.FriendDTO> SuggestedFriends
    {
        get
        {
            if (Friends == null) return Array.Empty<FriendClient.FriendDTO>();
            var memberIds = (Members ?? new()).Select(m => m.User?.Id).Where(id => id != null).ToHashSet();
            var query = (inviteQuery ?? "").Trim();
            return Friends
                .Where(f => !memberIds.Contains(f.UserId))
                .Where(f => string.IsNullOrEmpty(query)
                    || (f.Name?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false)
                    || (f.Handle?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false))
                .Take(string.IsNullOrEmpty(query) ? 3 : 10);
        }
    }

    private string GetTeamInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private async Task Close()
    {
        activeTab = "general";
        errorMessage = null;
        showDeleteConfirm = false;
        deleteConfirmText = "";
        inviteQuery = "";
        await OnClose.InvokeAsync();
    }

    private async Task DoRename()
    {
        if (!RenameChanged) return;
        errorMessage = null;
        isSaving = true;
        try { await OnRename.InvokeAsync(editTeamName.Trim()); }
        finally { isSaving = false; }
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteConfirmText = "";
    }

    private async Task DoDelete()
    {
        if (Team == null || deleteConfirmText != Team.Name) return;
        errorMessage = null;
        isDeleting = true;
        try { await OnDelete.InvokeAsync(); }
        finally
        {
            isDeleting = false;
            showDeleteConfirm = false;
            deleteConfirmText = "";
        }
    }

    private async Task AddMember(string userId)
    {
        errorMessage = null;
        isInviting = true;
        try { await OnAddMember.InvokeAsync(userId); }
        finally
        {
            isInviting = false;
            inviteQuery = "";
        }
    }

    private async Task RemoveMember(string userId)
    {
        errorMessage = null;
        await OnRemove.InvokeAsync(userId);
    }

    private async Task HandleRoleChange(string userId, string newRole)
    {
        errorMessage = null;
        if (newRole == "Admin") await OnPromote.InvokeAsync(userId);
        else await OnDemote.InvokeAsync(userId);
    }

    // ---------- Transfer ownership ----------
    private void StartTransferOwnership(string userId)
    {
        transferTargetId = userId;
    }

    private void CancelTransfer()
    {
        transferTargetId = null;
    }

    private async Task ConfirmTransfer()
    {
        if (string.IsNullOrEmpty(transferTargetId)) return;
        errorMessage = null;
        isTransferring = true;
        try { await OnTransferOwnership.InvokeAsync(transferTargetId); }
        finally
        {
            isTransferring = false;
            transferTargetId = null;
        }
    }

    // ---------- Bubble color helpers ----------

    private string SafeHex(string color)
    {
        // <input type="color"> only accepts #RRGGBB. For oklch() / named colors,
        // fall back to a neutral default so the picker mounts cleanly.
        if (string.IsNullOrEmpty(color)) return "#10b981";
        if (color.StartsWith("#") && (color.Length == 7 || color.Length == 4)) return color;
        return "#10b981";
    }

    private int GetHue(string color)
    {
        // Pull the third numeric token out of oklch(0.68 0.16 H). Default 165
        // (teal) when the color is a hex/named value where hue isn't trivial.
        if (string.IsNullOrEmpty(color) || !color.StartsWith("oklch", StringComparison.OrdinalIgnoreCase))
            return 165;
        try
        {
            var inside = color[color.IndexOf('(')..color.IndexOf(')')].Trim('(', ')');
            var parts = inside.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 3 && double.TryParse(parts[2], System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var h))
                return (int)Math.Round(h);
        }
        catch { }
        return 165;
    }

    // Auto-persist handlers — every drag immediately fires the parent's
    // BubbleColorChange callback, which updates the shared userBubbleColors
    // dict and persists server-side. Matches the chat header picker.
    private async Task OnPickerInput(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (!string.IsNullOrEmpty(v)) await OnBubbleColorChange.InvokeAsync(v);
    }

    private async Task OnSliderInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var hue)) return;
        await OnBubbleColorChange.InvokeAsync($"oklch(0.68 0.16 {hue})");
    }

    private async Task OnHexInput(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(v)) await OnBubbleColorChange.InvokeAsync(v);
    }

    private async Task DoBubbleReset()
    {
        await OnBubbleColorReset.InvokeAsync();
    }

    // ---------- Image URL ----------

    private string? ResolveImageUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return null;
        if (url.StartsWith("http")) return url;
        return $"{ApiBaseUrl}{url}";
    }
}
