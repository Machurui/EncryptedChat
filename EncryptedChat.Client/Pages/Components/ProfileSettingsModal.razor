    private string GetPasswordInfoText()
    {
        if (!passwordChangedAt.HasValue)
            return "Never changed";

        var days = (DateTime.UtcNow - passwordChangedAt.Value).Days;

        if (days == 0)
            return "Changed today";
        if (days == 1)
            return "Changed yesterday";
        if (days < 7)
            return $"Changed {days} days ago";
        if (days < 30)
            return $"Changed {days / 7} weeks ago";
        return $"Changed {days} days ago";
    }

    private string GetRecoveryInfoText()
