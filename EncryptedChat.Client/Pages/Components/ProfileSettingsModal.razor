@namespace EncryptedChat.Client.Pages.Components
@inject UserClient UserClient
@inject SecurityClient _securityClient
@inject EncryptedChat.Client.Services.Crypto.BootstrapKeyService BootstrapKeys
@inject IJSRuntime JS
@inject RecentNameColorsService RecentNameColors

@{
    const string ApiBaseUrl = "https://localhost:7294";
    string? GetFullImageUrl(string? url) => string.IsNullOrEmpty(url) ? null : (url.StartsWith("http") ? url : $"{ApiBaseUrl}{url}");
}

<Modal IsOpen="IsOpen" OnClose="Close"
       Eyebrow="@(securityView != null ? "Security & keys" : "Account")"
       Title="@GetModalTitle()"
       Size="lg" BodyFlush="true" BodyClass="modal-body-fill">
    <Leading>
        @if (securityView != null)
        {
            <button class="back-btn" @onclick='() => { securityView = null; ResetRecoveryViewState(); }'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
        }
    </Leading>
    <ChildContent>
                <div class="profile-modal-body">
                    @if (securityView != null)
                    {
                        <!-- Full-width security subview (no tabs) -->
                        <div class="profile-modal-content-full">
                            @if (securityView == "password")
                            {
                                <div class="profile-section">
                                    <div class="encryption-banner">
                                        <svg class="encryption-banner-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                                        </svg>
                                        <div>
                                            <div class="encryption-banner-title">Your password protects your local keys</div>
                                            <div class="encryption-banner-text">Changing it re-encrypts your private keys. Make sure your recovery phrase is saved before continuing.</div>
                                        </div>
                                    </div>

                                    <div class="profile-field">
                                        <label class="profile-field-label">Current password</label>
                                        <GlassInput Type="password" @bind-Value="currentPassword" Placeholder="Enter your current password" />
                                    </div>

                                    <div class="profile-field">
                                        <div class="field-header-with-status">
                                            <label class="profile-field-label">New password</label>
                                            @if (!string.IsNullOrEmpty(newPassword))
                                            {
                                                <span class="password-strength @GetPasswordStrengthClass()">@GetPasswordStrengthLabel()</span>
                                            }
                                        </div>
                                        <GlassInput Type="password" @bind-Value="newPassword" Placeholder="At least 14 characters" />
                                        @if (!string.IsNullOrEmpty(newPassword))
                                        {
                                            <div class="password-strength-bar">
                                                @for (int i = 0; i < 4; i++)
                                                {
                                                    <div class="strength-segment @(i < GetPasswordScore() ? "active" : "") @GetPasswordStrengthClass()"></div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="profile-field">
                                        <div class="field-header-with-status">
                                            <label class="profile-field-label">Confirm new password</label>
                                            @if (!string.IsNullOrEmpty(confirmPassword))
                                            {
                                                @if (newPassword == confirmPassword)
                                                {
                                                    <span class="password-match">
                                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                            <polyline points="20 6 9 17 4 12"/>
                                                        </svg>
                                                        Match
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="password-mismatch">Doesn't match</span>
                                                }
                                            }
                                        </div>
                                        <GlassInput Type="password" @bind-Value="confirmPassword" Placeholder="Re-enter new password" />
                                    </div>

                                    <div class="info-box">
                                        <div style="font-weight: 600; color: var(--text-primary); margin-bottom: 4px; font-size: 12px;">Strong password tips</div>
                                        Use a passphrase of 4 or more random words, or a 16+ character mix. Avoid reusing passwords from other accounts.
                                    </div>

                                    @if (!string.IsNullOrEmpty(passwordError))
                                    {
                                        <div class="error-box">@passwordError</div>
                                    }

                                    <div class="security-actions">
                                        <GlassButton OnClick='() => securityView = null'>Cancel</GlassButton>
                                        <GlassButton Primary="true" OnClick="HandleChangePassword" Disabled="@(!CanChangePassword())">
                                            @if (isChangingPassword)
                                            {
                                                <span>Updating...</span>
                                            }
                                            else
                                            {
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 6px;">
                                                    <polyline points="20 6 9 17 4 12"/>
                                                </svg>
                                                <span>Update password</span>
                                            }
                                        </GlassButton>
                                    </div>
                                </div>
                            }
                            else if (securityView == "recovery")
                            {
                                <div class="profile-section">
                                    @if (recoveryPhrase == null)
                                    {
                                        <div class="warning-banner">
                                            <svg class="warning-banner-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                            </svg>
                                            <div>
                                                <div class="warning-banner-title">We can't show you your existing phrase</div>
                                                <div class="warning-banner-text">If you've lost your recovery phrase, regenerate a new one. <strong>This invalidates your current phrase. Save the new one immediately &mdash; we cannot show it again.</strong></div>
                                            </div>
                                        </div>

                                        <div class="recovery-hidden-box">
                                            <div class="recovery-icon-box">
                                                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                                                    <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                                                </svg>
                                            </div>
                                            <div class="recovery-hidden-title">Regenerate your recovery phrase</div>
                                            <div class="recovery-hidden-text">A new 12-word phrase will be generated and your previous one will stop working.</div>

                                            @if (!string.IsNullOrEmpty(recoveryError))
                                            {
                                                <div class="error-text">@recoveryError</div>
                                            }

                                            <GlassButton Primary="true" OnClick="HandleRegenerateRecovery" Disabled="@isLoadingRecovery">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                                                    <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
                                                    <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
                                                </svg>
                                                @(isLoadingRecovery ? "Generating..." : "Generate new phrase")
                                            </GlassButton>
                                        </div>

                                        <div class="security-actions">
                                            <GlassButton OnClick='() => { securityView = null; ResetRecoveryViewState(); }'>Close</GlassButton>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="recovery-info-row">
                                            <div style="font-size: 11.5px; color: rgba(var(--text-rgb), 0.65);">Write these 12 words in order. We can't show them again.</div>
                                        </div>

                                        <div class="recovery-grid">
                                            @for (int i = 0; i < recoveryPhrase.Count; i++)
                                            {
                                                var index = i;
                                                <div class="recovery-word">
                                                    <span class="recovery-word-num">@(index + 1)</span>
                                                    @recoveryPhrase[index]
                                                </div>
                                            }
                                        </div>

                                        <div class="recovery-actions">
                                            <GlassButton OnClick="CopyRecoveryPhrase" Style="flex: 1;">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                                                    <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                                                </svg>
                                                Copy to clipboard
                                            </GlassButton>
                                        </div>

                                        <button class="recovery-confirm-btn @(recoveryConfirmed ? "confirmed" : "")" @onclick="() => recoveryConfirmed = !recoveryConfirmed">
                                            <span class="recovery-checkbox @(recoveryConfirmed ? "checked" : "")">
                                                @if (recoveryConfirmed)
                                                {
                                                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                                        <polyline points="20 6 9 17 4 12"/>
                                                    </svg>
                                                }
                                            </span>
                                            I've written down my new recovery phrase in a safe place.
                                        </button>

                                        <div class="security-actions">
                                            <GlassButton Primary="true" OnClick='() => { securityView = null; ResetRecoveryViewState(); }' Disabled="@(!recoveryConfirmed)">
                                                Done
                                            </GlassButton>
                                        </div>
                                    }
                                </div>
                            }
                            else if (securityView == "sessions")
                            {
                                <div class="profile-section">
                                    <div class="sessions-header">
                                        <div style="font-size: 11.5px; color: rgba(var(--text-rgb), 0.65);">
                                            You're signed in on @sessions.Count device@(sessions.Count == 1 ? "" : "s"). Revoking a session ends it immediately.
                                        </div>
                                        @if (sessions.Count > 1)
                                        {
                                            <button class="signout-others-btn" @onclick="HandleSignOutOthers">Sign out all other devices</button>
                                        }
                                    </div>

                                    <div class="sessions-list">
                                        @foreach (var session in sessions)
                                        {
                                            <div class="session-row @(session.IsCurrent ? "current" : "") @(IsSessionStale(session) ? "stale" : "")">
                                                <div class="session-icon">
                                                    @if (session.DeviceKind == "mobile")
                                                    {
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/>
                                                        </svg>
                                                    }
                                                    else
                                                    {
                                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                                        </svg>
                                                    }
                                                </div>
                                                <div class="session-info">
                                                    <div class="session-device">
                                                        <span>@session.DeviceInfo</span>
                                                        @if (session.IsCurrent)
                                                        {
                                                            <span class="session-badge current">This device</span>
                                                        }
                                                        @if (IsSessionStale(session))
                                                        {
                                                            <span class="session-badge stale">Inactive</span>
                                                        }
                                                    </div>
                                                    <div class="session-meta">
                                                        <span>@(session.Location ?? "Unknown")</span>
                                                        <span>·</span>
                                                        <span class="session-ip">@(session.IpAddress ?? "—")</span>
                                                        <span>·</span>
                                                        <span class="@(session.IsCurrent ? "session-active" : "")">@GetSessionLastActive(session)</span>
                                                    </div>
                                                </div>
                                                @if (!session.IsCurrent)
                                                {
                                                    <button class="revoke-btn" @onclick="() => HandleRevokeSession(session.Id)">Revoke</button>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="info-box">
                                        See an unfamiliar device? Revoke it immediately and change your password. We'll notify each device when its session ends.
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Normal view with sidebar tabs -->
                        <div class="profile-modal-tabs">
                            <button class="profile-tab @(activeTab == "profile" ? "active" : "")" @onclick='() => activeTab = "profile"'>
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 006 0v-1a10 10 0 10-3.92 7.94"/>
                                </svg>
                                <span>Profile</span>
                            </button>
                            <button class="profile-tab @(activeTab == "status" ? "active" : "")" @onclick='() => activeTab = "status"'>
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>
                                </svg>
                                <span>Status</span>
                            </button>
                            <button class="profile-tab @(activeTab == "privacy" ? "active" : "")" @onclick='() => activeTab = "privacy"'>
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                </svg>
                                <span>Privacy</span>
                            </button>
                            <button class="profile-tab @(activeTab == "security" ? "active" : "")" @onclick="OpenSecurityTab">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="8" cy="15" r="4"/><path d="m11 12 9-9M16 7l3 3"/>
                                </svg>
                                <span>Security & keys</span>
                            </button>
                        </div>

                        <div class="profile-modal-content">
                            @if (activeTab == "profile")
                        {
                            <div class="profile-section">
                                <!-- Avatar -->
                                <div class="profile-avatar-section">
                                    <div class="profile-avatar-large">
                                        @if (!string.IsNullOrEmpty(ProfileImageUrl))
                                        {
                                            <img src="@GetFullImageUrl(ProfileImageUrl)" alt="@Name" class="avatar-image" />
                                        }
                                        else
                                        {
                                            <div class="avatar-placeholder" style="background: linear-gradient(135deg, @GetAvatarGradient(Name));">
                                                @GetInitials(Name)
                                            </div>
                                        }
                                        <div class="avatar-status-dot @Status"></div>
                                    </div>
                                    <div class="profile-avatar-actions">
                                        <label class="upload-btn">
                                            <InputFile OnChange="HandleAvatarUpload" accept="image/jpeg,image/png,image/gif,image/webp" style="display: none;" />
                                            <span class="glass-btn glass-btn-sm">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
                                                </svg>
                                                @(isUploadingAvatar ? "Uploading..." : "Upload photo")
                                            </span>
                                        </label>
                                        @if (!string.IsNullOrEmpty(ProfileImageUrl))
                                        {
                                            <button class="link-btn" style="font-size: 11px; color: rgba(var(--text-rgb), 0.55);" @onclick="RemoveAvatar" disabled="@isUploadingAvatar">Remove</button>
                                        }
                                    </div>
                                </div>

                                <!-- Name fields -->
                                <div class="profile-fields-grid">
                                    <div class="profile-field">
                                        <label class="profile-field-label">Display name</label>
                                        <GlassInput @bind-Value="localName" Placeholder="Your name" />
                                    </div>
                                    <div class="profile-field">
                                        <label class="profile-field-label">Handle</label>
                                        @* Locked when Handle is set (the normal case for users registered after the
                                           refactor). The editable branch below covers legacy accounts that pre-date
                                           the refactor and never claimed a handle — they get one shot to claim. *@
                                        @if (!string.IsNullOrWhiteSpace(localHandle))
                                        {
                                            <div class="handle-locked">
                                                <span class="handle-locked-text">@@@(localHandle)</span>
                                                <span class="handle-locked-icon" title="Handle is permanent and cannot be changed">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                                                    </svg>
                                                </span>
                                            </div>
                                            <div class="handle-helper-text">Handle is permanent — cannot be changed.</div>
                                        }
                                        else
                                        {
                                            <GlassInput @bind-Value="localHandle" Placeholder="your_handle">
                                                <Icon>
                                                    <span style="color: var(--text-muted);">@@</span>
                                                </Icon>
                                            </GlassInput>
                                            <div class="handle-helper-text">Choose your handle. Letters, numbers, underscore (3–32 chars). This cannot be changed later.</div>
                                        }
                                    </div>
                                </div>

                                <div class="profile-field">
                                    <label class="profile-field-label">Name color</label>

                                    <label class="name-color-preview" style="--ncc: @NameColor;">
                                        <input type="color" class="name-color-native-input"
                                               value="@SafeHexFor(NameColor)"
                                               @onchange="OnNativePickerChange" />
                                        <span class="name-color-glow"></span>
                                        <div class="name-color-preview-row">
                                            <Avatar Name="@Name" ImageUrl="@ProfileImageUrl" Size="36" />
                                            <div class="name-color-preview-text">
                                                <div class="name-color-preview-name" style="color: @NameColor;">@(string.IsNullOrWhiteSpace(Name) ? "Your name" : Name)</div>
                                                <div class="name-color-preview-handle">@@@(string.IsNullOrWhiteSpace(Handle) ? "you" : Handle) · how others will see you</div>
                                            </div>
                                            <span class="name-color-pick-pill">
                                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M12 2.69 5.5 9.19a9.19 9.19 0 1 0 13 0Z" fill="currentColor" fill-opacity="0.18" />
                                                </svg>
                                                Pick
                                            </span>
                                        </div>
                                    </label>

                                    <div class="name-color-controls">
                                        <div class="name-color-slider-track">
                                            <input type="range" min="0" max="360" step="1"
                                                   value="@GetHue(NameColor)"
                                                   @oninput="OnHueChange"
                                                   class="name-color-slider" />
                                        </div>
                                        <input type="text" class="name-color-text-input"
                                               value="@NameColor"
                                               @onchange="OnTextChange"
                                               placeholder="#10B981"
                                               spellcheck="false" />
                                    </div>

                                    <div class="name-color-helper">
                                        Click the preview for the system RGB picker, drag the rainbow to skim hues,
                                        or paste any CSS color (hex, rgb, hsl, oklch).
                                    </div>

                                    @if (recentNameColors.Count > 0)
                                    {
                                        <div class="name-color-recent">
                                            <div class="name-color-recent-label">Recent</div>
                                            <div class="name-color-recent-swatches">
                                                @foreach (var c in recentNameColors)
                                                {
                                                    var color = c;
                                                    <button type="button" class="name-color-recent-swatch"
                                                            style="background: @color;"
                                                            @onclick="() => ApplyColor(color)"
                                                            title="@color"></button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="divider"></div>

                                <div class="profile-field">
                                    <label class="profile-field-label">Theme</label>
                                    <div class="theme-options">
                                        @foreach (var themeOption in themeOptions)
                                        {
                                            var isSelected = Theme == themeOption.Key;
                                            <button class="theme-option @(isSelected ? "selected" : "")" @onclick="() => OnThemePicked(themeOption.Key)">
                                                <span class="theme-icon">@themeOption.Value.Icon</span>
                                                <span class="theme-label">@themeOption.Value.Label</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else if (activeTab == "status")
                        {
                            <div class="profile-section">
                                <div class="profile-field">
                                    <label class="profile-field-label">Availability</label>
                                    <div class="status-options">
                                        @foreach (var preset in statusPresets)
                                        {
                                            var isSelected = localStatus == preset.Key;
                                            <button class="status-option @(isSelected ? "selected" : "")"
                                                    style="@(isSelected ? $"background: {GetStatusDimColor(preset.Key)};" : "")"
                                                    @onclick="() => localStatus = preset.Key">
                                                <span class="status-option-dot @preset.Key"></span>
                                                <span class="status-option-label">@preset.Value</span>
                                                @if (isSelected)
                                                {
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                        <polyline points="20 6 9 17 4 12"/>
                                                    </svg>
                                                }
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="profile-field">
                                    <label class="profile-field-label">Custom status message</label>
                                    <GlassInput @bind-Value="localStatusMessage" Placeholder="What are you up to?" />
                                </div>

                                <div class="info-box">
                                    Your status is visible to your friends and team members. It is end-to-end encrypted and never logged on our servers.
                                </div>
                            </div>
                        }
                        else if (activeTab == "privacy")
                        {
                            <div class="profile-section" style="gap: 4px;">
                                <!-- Typing indicators toggle -->
                                <div class="toggle-row">
                                    <div class="toggle-row-info">
                                        <div class="toggle-row-label">Typing indicators</div>
                                        <div class="toggle-row-desc">Show when you're typing in a conversation.</div>
                                    </div>
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@localTypingIndicators" @onchange="e => ToggleTypingIndicators((bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </div>

                                <div class="divider" style="margin: 8px 0;"></div>

                                <!-- Notifications -->
                                <div class="notification-section">
                                    <div class="notification-header">Notifications</div>
                                    <div class="notification-desc">Choose when EncryptedChat alerts you.</div>
                                    <div class="notification-options">
                                        <button class="notification-option @(localNotificationPreference == "all" ? "selected" : "")" @onclick='() => SelectNotificationPreference("all")'>
                                            <span class="notification-radio @(localNotificationPreference == "all" ? "selected" : "")">
                                                @if (localNotificationPreference == "all") { <span class="notification-radio-dot"></span> }
                                            </span>
                                            <span>Every message</span>
                                        </button>
                                        <button class="notification-option @(localNotificationPreference == "mentions" ? "selected" : "")" @onclick='() => SelectNotificationPreference("mentions")'>
                                            <span class="notification-radio @(localNotificationPreference == "mentions" ? "selected" : "")">
                                                @if (localNotificationPreference == "mentions") { <span class="notification-radio-dot"></span> }
                                            </span>
                                            <span>Only @@mentions and DMs</span>
                                        </button>
                                        <button class="notification-option @(localNotificationPreference == "none" ? "selected" : "")" @onclick='() => SelectNotificationPreference("none")'>
                                            <span class="notification-radio @(localNotificationPreference == "none" ? "selected" : "")">
                                                @if (localNotificationPreference == "none") { <span class="notification-radio-dot"></span> }
                                            </span>
                                            <span>Nothing — I'll check manually</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (activeTab == "security")
                        {
                            <div class="profile-section">
                                <!-- E2EE Banner -->
                                <div class="encryption-banner">
                                    <svg class="encryption-banner-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                    </svg>
                                    <div>
                                        <div class="encryption-banner-title">End-to-end encryption active</div>
                                        <div class="encryption-banner-text">Your messages are end-to-end encrypted. Only you and the recipients can read them.</div>
                                    </div>
                                </div>

                                <div class="security-row">
                                    <div class="security-row-info">
                                        <div class="security-row-label">Recovery phrase</div>
                                        <div class="security-row-value">@GetRecoveryInfoText()</div>
                                    </div>
                                    <GlassButton Size="sm" OnClick='() => securityView = "recovery"'>Manage</GlassButton>
                                </div>

                                <div class="security-row">
                                    <div class="security-row-info">
                                        <div class="security-row-label">Active sessions</div>
                                        <div class="security-row-value">@GetSessionsInfoText()</div>
                                    </div>
                                    <GlassButton Size="sm" OnClick='() => OpenSessionsView()'>Manage</GlassButton>
                                </div>

                                <div class="security-row">
                                    <div class="security-row-info">
                                        <div class="security-row-label">Password</div>
                                        <div class="security-row-value">@GetPasswordInfoText()</div>
                                    </div>
                                    <GlassButton Size="sm" OnClick='() => securityView = "password"'>Change</GlassButton>
                                </div>

                                <button class="signout-all-btn" @onclick="HandleSignOutEverywhere">Sign out everywhere</button>
                            </div>
                        }
                        </div>
                    }
                </div>
    </ChildContent>
    <Footer>
        @if (securityView == null)
        {
            <GlassButton OnClick="Close">Cancel</GlassButton>
            <GlassButton Primary="true" OnClick="Save">Save changes</GlassButton>
        }
    </Footer>
</Modal>

