    private async Task HandleRegenerateRecovery()
    {
        isLoadingRecovery = true;
        recoveryError = null;
        StateHasChanged();

        try
        {
            // The Password field on RecoveryPhraseRequestDTO is [Required] for
            // model validation but unused by the current server implementation
            // — auth is via cookie. Pass a placeholder so ModelState is valid.
            var result = await _securityClient.RegenerateRecoveryPhraseAsync("regenerate");
            if (result.Success && result.Value != null)
            {
                // Re-wrap the identity private keys with the freshly-derived
                // wrap-key so they stay unwrap-able with the new phrase
                // (otherwise the user's bundle would orphan: old phrase still
                // unwraps it on the server, but the old phrase is now invalid).
                var profile = await UserClient.GetProfileAsync();
                if (profile.Success && profile.Value != null)
                {
                    string newPhrase = string.Join(' ', result.Value.Words);
                    bool rewrapped = await BootstrapKeys.ReWrapAsync(profile.Value.Id, newPhrase);
                    if (!rewrapped)
                    {
                        recoveryError = "Phrase regenerated but the key bundle re-wrap failed. The old phrase may still unwrap the server-side bundle until you regenerate again or log out.";
                    }
                }

                recoveryPhrase = result.Value.Words.ToList();
                recoveryConfirmed = false;
            }
            else
            {
                recoveryError = result.Error ?? "Failed to regenerate recovery phrase.";
            }
        }
        finally
        {
            isLoadingRecovery = false;
            StateHasChanged();
        }
    }

    private async Task CopyRecoveryPhrase()
    {
        if (recoveryPhrase == null) return;
        var text = string.Join(" ", recoveryPhrase);
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        }
        catch
        {
            // Fallback for older browsers - silently fail
        }
    }

    private void ResetRecoveryViewState()
    {
        recoveryPhrase = null;
        recoveryConfirmed = false;
        recoveryError = null;
        isLoadingRecovery = false;
    }

    private async Task OpenSessionsView()
    {
        securityView = "sessions";
        var result = await _securityClient.GetSessionsAsync();
        if (result.Success && result.Value != null)
        {
            sessions = result.Value.Sessions;
        }
    }

    private string GetSessionLastActive(SecurityClient.SessionInfo session)
    {
        if (session.IsCurrent)
            return "Active now";

        var minutes = (DateTime.UtcNow - session.LastActiveAt).TotalMinutes;

        if (minutes < 1)
            return "Active now";
        if (minutes < 60)
            return $"{(int)minutes} minutes ago";
        if (minutes < 1440)
            return $"{(int)(minutes / 60)} hours ago";
        return $"{(int)(minutes / 1440)} days ago";
    }

    private bool IsSessionStale(SecurityClient.SessionInfo session)
    {
        return (DateTime.UtcNow - session.LastActiveAt).TotalDays > 7;
    }

    private async Task HandleRevokeSession(Guid sessionId)
    {
        var result = await _securityClient.RevokeSessionAsync(sessionId);
        if (result.Success)
        {
            sessions = sessions.Where(s => s.Id != sessionId).ToList();
        }
    }

    private async Task HandleSignOutOthers()
    {
        var result = await _securityClient.RevokeAllOtherSessionsAsync();
        if (result.Success)
        {
            sessions = sessions.Where(s => s.IsCurrent).ToList();
        }
    }

    private async Task HandleSignOutEverywhere()
    {
        await HandleSignOutOthers();
        await HandleLogout();
    }
}
