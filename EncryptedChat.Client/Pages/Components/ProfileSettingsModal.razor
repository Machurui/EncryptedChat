    private static readonly System.Text.RegularExpressions.Regex CssColorRegex = new(
        @"^(#[0-9A-Fa-f]{6}|rgba?\([^)]{1,80}\)|hsla?\([^)]{1,80}\)|okl(ch|ab)\([^)]{1,80}\))$",
        System.Text.RegularExpressions.RegexOptions.Compiled);

    private static readonly System.Text.RegularExpressions.Regex HexColorRegex = new(
        @"^#[0-9A-Fa-f]{6}$", System.Text.RegularExpressions.RegexOptions.Compiled);

    // Hex coercion for the native <input type="color"> (which only accepts hex).
    // For non-hex values, fall back to a neutral default.
    private string SafeHexFor(string cssColor)
    {
        if (string.IsNullOrEmpty(cssColor)) return "#888888";
        return HexColorRegex.IsMatch(cssColor) ? cssColor : "#888888";
    }

    // Extract hue 0-360 from a CSS color so the rainbow slider position reflects it.
    private int GetHue(string cssColor)
    {
        if (string.IsNullOrEmpty(cssColor)) return 165;

        var oklchMatch = System.Text.RegularExpressions.Regex.Match(
            cssColor,
            @"^oklch\(\s*[\d.]+\s+[\d.]+\s+([\d.]+)",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (oklchMatch.Success && double.TryParse(
                oklchMatch.Groups[1].Value,
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture,
                out var h))
        {
            return ((int)Math.Round(h) % 360 + 360) % 360;
        }

        if (HexColorRegex.IsMatch(cssColor))
            return HexToHue(cssColor);

        return 165;
    }

    private static int HexToHue(string hex)
    {
        var r = Convert.ToInt32(hex.Substring(1, 2), 16) / 255.0;
        var g = Convert.ToInt32(hex.Substring(3, 2), 16) / 255.0;
        var b = Convert.ToInt32(hex.Substring(5, 2), 16) / 255.0;
        var max = Math.Max(r, Math.Max(g, b));
        var min = Math.Min(r, Math.Min(g, b));
        var d = max - min;
        if (d == 0) return 0;
        double hueSegment;
        if (max == r) hueSegment = ((g - b) / d) % 6;
        else if (max == g) hueSegment = (b - r) / d + 2;
        else hueSegment = (r - g) / d + 4;
        var hueDeg = hueSegment * 60;
        return ((int)Math.Round(hueDeg) % 360 + 360) % 360;
    }

