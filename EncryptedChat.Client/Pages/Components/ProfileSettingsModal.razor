    private string GetAvatarGradient(string name)
    {
        var hash = name?.GetHashCode() ?? 0;
        var hue1 = Math.Abs(hash % 360);
        var hue2 = (hue1 + 40) % 360;
        return $"oklch(0.65 0.15 {hue1}), oklch(0.45 0.12 {hue2})";
