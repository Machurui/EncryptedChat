    private string GetSessionsInfoText()
    {
        if (sessions.Count == 0)
            return "Loading...";

        var webCount = sessions.Count(s => s.DeviceKind == "web");
        var mobileCount = sessions.Count(s => s.DeviceKind == "mobile");

        var parts = new List<string>();
        if (webCount > 0) parts.Add($"{webCount} web");
        if (mobileCount > 0) parts.Add($"{mobileCount} mobile");

        return $"{sessions.Count} device{(sessions.Count == 1 ? "" : "s")} · {string.Join(", ", parts)}";
