    private async Task HandleAvatarUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        if (file.Size > 5 * 1024 * 1024)
        {
            return; // File too large
        }

        var allowedTypes = new[] { "image/jpeg", "image/png", "image/gif", "image/webp" };
        if (!allowedTypes.Contains(file.ContentType.ToLowerInvariant()))
        {
            return; // Invalid file type
        }

        isUploadingAvatar = true;
        StateHasChanged();
        try
        {
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var result = await UserClient.UploadAvatarAsync(stream, file.Name, file.ContentType);
            if (result.Success && result.Value != null)
            {
                ProfileImageUrl = result.Value.Url;
                await ProfileImageUrlChanged.InvokeAsync(ProfileImageUrl);
            }
        }
        finally
        {
            isUploadingAvatar = false;
            StateHasChanged();
        }
    }

