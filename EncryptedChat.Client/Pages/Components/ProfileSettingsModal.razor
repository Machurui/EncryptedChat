        var sessionsTask = _securityClient.GetSessionsAsync();

        await Task.WhenAll(passwordTask, sessionsTask);

        if (passwordTask.Result.Success)
            passwordChangedAt = passwordTask.Result.Value?.ChangedAt;

        if (sessionsTask.Result.Success && sessionsTask.Result.Value != null)
            sessions = sessionsTask.Result.Value.Sessions;
