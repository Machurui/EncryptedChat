@namespace EncryptedChat.Client.Pages.Components

<button class="@CssClass" style="@Style" disabled="@Disabled" @onclick="OnClick">
    @if (Icon != null)
    {
        @Icon
    }
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public bool Primary { get; set; }
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private string CssClass
    {
        get
        {
            var classes = new List<string> { "glass-btn" };

            if (Primary) classes.Add("glass-btn-primary");

            if (Size == "sm") classes.Add("glass-btn-sm");
            else if (Size == "lg") classes.Add("glass-btn-lg");

            return string.Join(" ", classes);
        }
    }
}
