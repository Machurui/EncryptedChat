@using EncryptedChat.Client.Services

<style>
    .mobile-only {
        display: block;
    }
    .desktop-only {
        display: none;
    }
    @@media (min-width: 768px) {
        .mobile-only {
            display: none !important;
        }
        .desktop-only {
            display: flex !important;
        }
    }
</style>

<header class="antialiased w-full">
    <nav class="relative w-full bg-cover bg-center bg-no-repeat border-gray-200 px-4 lg:px-6 py-2.5">
        <!-- Glass layers -->
        <div class="liquid-glass-effect-no-blur" style="border-radius: 20px;"></div>
        <div class="liquid-glass-tint-no-bg" style="border-radius: 20px;"></div>
        <div class="liquid-glass-shine-no-bs" style="border-radius: 20px;"></div>

        <!-- Content -->
        <div class="liquid-glass-content">
            <div class="max-w-7xl mx-auto px-4 md:px-6 py-3 md:py-4">
                <div class="flex items-center justify-between">
                    <!-- Logo -->
                    <div class="flex items-center">
                        <a href="/" class="flex items-center cursor-pointer">
                            <img src="https://logodix.com/logo/1305364.png" class="mr-2 md:mr-3 h-6 md:h-8" alt="Logo" />
                            <span class="self-center text-lg md:text-2xl font-semibold whitespace-nowrap text-white">EntraChat</span>
                        </a>
                    </div>

                    <!-- Mobile menu button (hidden on desktop) -->
                    <button type="button" class="mobile-only text-white p-2 cursor-pointer" id="mobile-menu-btn" @onclick="ToggleMobileMenu">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            @if (isMobileMenuOpen)
                            {
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            }
                            else
                            {
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            }
                        </svg>
                    </button>

                    <!-- Desktop Links -->
                    <div class="hidden md:flex items-center space-x-8">
                        <a href="/" class="text-white/80 hover:text-white transition-colors cursor-pointer">Home</a>
                        <AuthorizeView>
                            <Authorized>
                                <a href="/team" class="text-white/80 hover:text-white transition-colors cursor-pointer">Teams</a>
                                <a href="/friends" class="text-white/80 hover:text-white transition-colors cursor-pointer">Friends</a>
                            </Authorized>
                        </AuthorizeView>
                    </div>

                    <!-- Desktop Auth -->
                    <div class="hidden md:flex items-center space-x-4">
                        <AuthorizeView>
                            <Authorized>
                                <button type="button" class="glass-button hover:bg-white/20 cursor-pointer">Profile</button>
                                <button type="button" @onclick="Logout" class="glass-button hover:bg-white/20 cursor-pointer">Logout</button>
                            </Authorized>

                            <NotAuthorized>
                                <NavLink class="glass-button hover:bg-white/20 items-center gap-2 cursor-pointer" href="/login" Match="NavLinkMatch.All">
                                    <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4 5v14" /><path d="M17 12H8" /><path d="M11 7l6 5-6 5" />
                                    </svg>
                                    <span class="leading-none whitespace-nowrap">Sign In</span>
                                </NavLink>

                                <NavLink class="glass-button hover:bg-white/20 items-center gap-2 cursor-pointer" href="/register">
                                    <svg class="w-5 h-5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="9" cy="8" r="3" /><path d="M2 20a7 7 0 0 1 14 0" /><path d="M19 6v4" /><path d="M17 8h4" />
                                    </svg>
                                    <span class="leading-none whitespace-nowrap">Sign Up</span>
                                </NavLink>
                            </NotAuthorized>
                        </AuthorizeView>
                    </div>
                </div>

                <!-- Mobile Menu -->
                @if (isMobileMenuOpen)
                {
                    <div class="md:hidden mt-4 pt-4 border-t border-white/10 space-y-3">
                        <a href="/" class="block text-white/80 hover:text-white transition-colors cursor-pointer py-2">Home</a>
                        <AuthorizeView>
                            <Authorized>
                                <a href="/team" class="block text-white/80 hover:text-white transition-colors cursor-pointer py-2">Teams</a>
                                <a href="/friends" class="block text-white/80 hover:text-white transition-colors cursor-pointer py-2">Friends</a>
                                <div class="pt-3 border-t border-white/10 space-y-2">
                                    <button type="button" class="w-full text-left glass-button hover:bg-white/20 cursor-pointer">Profile</button>
                                    <button type="button" @onclick="Logout" class="w-full text-left glass-button hover:bg-white/20 cursor-pointer">Logout</button>
                                </div>
                            </Authorized>

                            <NotAuthorized>
                                <div class="pt-3 border-t border-white/10 flex flex-col gap-2">
                                    <NavLink class="glass-button hover:bg-white/20 items-center gap-2 cursor-pointer justify-center" href="/login">
                                        <span>Sign In</span>
                                    </NavLink>
                                    <NavLink class="glass-button hover:bg-white/20 items-center gap-2 cursor-pointer justify-center" href="/register">
                                        <span>Sign Up</span>
                                    </NavLink>
                                </div>
                            </NotAuthorized>
                        </AuthorizeView>
                    </div>
                }
            </div>
        </div>
    </nav>
</header>

@code {
    private bool isMobileMenuOpen = false;

    private void ToggleMobileMenu()
    {
        isMobileMenuOpen = !isMobileMenuOpen;
    }

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    [Inject]
    private AuthClient AuthClient { get; set; } = default!;

    [Inject]
    private EncryptedChat.Client.Auth.CookieAuthStateProvider AuthStateProvider { get; set; } = default!;

    private async Task Logout()
    {
        await AuthClient.LogoutAsync();
        AuthStateProvider.NotifyChanged();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}