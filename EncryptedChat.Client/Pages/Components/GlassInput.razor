@namespace EncryptedChat.Client.Pages.Components

<div class="glass-input-wrapper" style="@Style">
    @if (Icon != null)
    {
        <span class="glass-input-icon">@Icon</span>
    }
    <input type="@Type"
           class="glass-input-field"
           style="font-size: @(FontSize)px;"
           placeholder="@Placeholder"
           value="@Value"
           @oninput="HandleInput"
           @onkeydown="HandleKeyDown"
           maxlength="@MaxLength"
           disabled="@Disabled" />
</div>

<style>
    .glass-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 12px;
        border-radius: 12px;
        border: 0.5px solid rgba(255,255,255,0.20);
        background: var(--bg-input);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: inset 1px 1px 2px rgba(255,255,255,0.20), inset -1px -1px 1px rgba(0,0,0,0.10);
    }

    .glass-input-wrapper:focus-within {
        border-color: var(--text-disabled);
    }

    .glass-input-icon {
        display: flex;
        align-items: center;
        color: var(--text-secondary);
        flex: 0 0 auto;
    }

    .glass-input-field {
        flex: 1;
        min-width: 0;
        background: transparent;
        border: none;
        outline: none;
        color: var(--text-primary);
        font-size: 14px;
        padding: 11px 0;
        font-family: inherit;
    }

    .glass-input-field::placeholder {
        color: rgba(255,255,255,0.40);
    }

    .glass-input-field:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public int MaxLength { get; set; } = 524288;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public int FontSize { get; set; } = 14;
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback<ChangeEventArgs> OnInput { get; set; }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);
        if (OnInput.HasDelegate)
            await OnInput.InvokeAsync(e);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && OnSubmit.HasDelegate)
        {
            await OnSubmit.InvokeAsync();
        }
    }
}
