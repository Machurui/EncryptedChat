    private string GetRelativeTimeFromDate(DateTime date)
    {
        var diff = DateTime.UtcNow - date;
        if (diff.TotalMinutes < 1) return "now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return date.ToLocalTime().ToString("MMM d");
    }

    private string FormatMessageTimestamp(DateTime utcDate)
    {
        var local = utcDate.ToLocalTime();
        var nowLocal = DateTime.Now;
        int daysDiff = (nowLocal.Date - local.Date).Days;

        if (daysDiff <= 0)
            return local.ToString("HH:mm");
        if (daysDiff == 1)
            return $"Yesterday {local:HH:mm}";
        if (daysDiff < 7)
            return local.ToString("ddd HH:mm");
        if (local.Year == nowLocal.Year)
            return local.ToString("MMM d");
        return local.ToString("MMM d, yyyy");
    }

