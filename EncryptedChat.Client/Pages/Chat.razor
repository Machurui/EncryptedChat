    private async Task InsertGif(GifResult gif)
    {
        // Close picker first (UX: feels instant)
        showGifPicker = false;
        gifSearch = "";

        // Preserve pending input text in case the user typed something
        var pending = newMessageText;
        newMessageText = gif.Url;

        await SendMessage();

        // SendMessage clears newMessageText on success.
        // If a rate-limit happened, newMessageText stays = gif.Url (existing IsInCooldown logic).
        // Only restore pending if the send went through (input is empty).
        if (string.IsNullOrEmpty(newMessageText))
            newMessageText = pending;

        // Re-size the composer to the restored draft (or collapse to one row when
        // there was none). resize() defers internally, so it measures the post-render DOM.
        try { await JS.InvokeVoidAsync("composerOverlay.resize", "composer-input"); } catch { }

        // Record in the synced vault (falls back to LocalStorage when the vault is unavailable).
        await GifVault.AddRecentAsync(new GifItem(gif.Url, gif.PreviewUrl, gif.Width, gif.Height,
                                                  Stickers ? "stickers" : "gifs", 0));
        recentGifsCount = GifVault.Available
            ? GifVault.Recents.Count
            : (await RecentGifs.GetAllAsync()).Count;
    }

