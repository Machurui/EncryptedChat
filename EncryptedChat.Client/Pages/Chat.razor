            currentTheme = result.Value.Theme;
            currentReadReceipts = result.Value.ReadReceipts;
            currentTypingIndicators = result.Value.TypingIndicators;
            currentNotificationPreference = (result.Value.NotificationPreference ?? "all").ToLowerInvariant().Trim();
            Console.WriteLine($"[Profile] Loaded NotificationPreference: '{currentNotificationPreference}'");
            editStatusMessage = currentStatusMessage ?? string.Empty;
            ApplyTheme(currentTheme);
            profileState = LoadState.Success;
