    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The composer textarea AND the messages-container are gated by
        // `@if (selectedTeam != null)`, so neither is in the DOM at firstRender —
        // wiring there silently no-ops (getElementById returns null) and the listeners
        // never attach. Wire them the first render after the chat pane mounts, and
        // reset on unmount so a later conversation re-wires. (No @key on the pane →
        // switching conversations reuses the same elements; these JS helpers are all
        // idempotent.)
        if (selectedTeam != null && !_chatPaneWired)
        {
            _chatPaneWired = true;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("setupMobileComposerScroll", "composer-input", "messages-container");
            await JS.InvokeVoidAsync("composerOverlay.sync", "composer-input", "composer-highlight");
            await JS.InvokeVoidAsync("setupMessagesScrollListener",
                "messages-container",
                _dotNetRef,
                nameof(LoadOlderMessagesJs),
                nameof(SetJumpToBottomVisible));
        }
        else if (selectedTeam == null && _chatPaneWired)
        {
            _chatPaneWired = false;
        }

        if (firstRender)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("popupRegistry.register",
                "chat-popups", _dotNetRef, nameof(CloseAllPopups), ".popup-container");
            _popupListenerRegistered = true;
        }

        // Attach the auto-scroll observer once the messages container is in the DOM.
        // chatScroll.attach is idempotent.
        if (selectedTeamId.HasValue)
        {
            try
            {
                await JS.InvokeVoidAsync("chatScroll.attach", "messages-container");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"chatScroll.attach failed: {ex.Message}");
            }
        }

        // Wire infinite scroll on the GIF picker sentinel when present
        if (showGifPicker && gifHasMore)
        {
            gifPickerDotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("gifPicker.observeLoadMore", gifLoadSentinelRef, gifPickerDotNetRef);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"gifPicker.observeLoadMore failed: {ex.Message}");
            }
        }
    }

    private async Task LoadTeams()
    {
        if (string.IsNullOrEmpty(_userId))
        {
            teamsState = LoadState.Error;
            teamsError = "User session not loaded.";
            return;
        }

        if (!teams.Any()) teamsState = LoadState.Loading;
        teamsError = null;

        try
        {
            var result = await TeamClient.GetTeamsByUserAsync(_userId);
            if (!result.Success)
            {
                teamsState = LoadState.Error;
                teamsError = result.ErrorMessage ?? "Failed to load teams.";
                return;
            }
            teams = result.Value ?? [];
            // Seed unread badges + mute state from the server (persisted across reloads/devices).
            foreach (var t in teams)
            {
                unreadCounts[t.Id] = t.UnreadCount;
                if (t.IsMuted) mutedTeams.Add(t.Id);
                else mutedTeams.Remove(t.Id);
            }
            teamsState = teams.Any() ? LoadState.Success : LoadState.Empty;
        }
        catch (Exception ex)
        {
            teamsState = LoadState.Error;
            teamsError = ex.Message;
        }
    }

