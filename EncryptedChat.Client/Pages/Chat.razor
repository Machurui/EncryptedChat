    private void OnRateLimited(int retryAfterMs)
    {
        cooldownUntilUtc = DateTime.UtcNow.AddMilliseconds(retryAfterMs);
        StartCooldownTimer();

        // Restore the message text if the input was cleared optimistically by the SignalR send path
        if (string.IsNullOrWhiteSpace(newMessageText) && !string.IsNullOrWhiteSpace(_lastAttemptedSendText))
        {
            newMessageText = _lastAttemptedSendText;
        }
        _lastAttemptedSendText = string.Empty;
    }

    private void StartCooldownTimer()
    {
        _cooldownTickTimer?.Stop();
        _cooldownTickTimer = new System.Timers.Timer(250);
        _cooldownTickTimer.Elapsed += async (_, _) =>
        {
            if (cooldownUntilUtc.HasValue && DateTime.UtcNow >= cooldownUntilUtc.Value)
            {
                cooldownUntilUtc = null;
                _cooldownTickTimer?.Stop();
            }
            await InvokeAsync(StateHasChanged);
        };
        _cooldownTickTimer.Start();
    }

    private bool IsInCooldown => cooldownUntilUtc.HasValue && DateTime.UtcNow < cooldownUntilUtc.Value;

    private int RemainingCooldownSec => cooldownUntilUtc.HasValue
        ? Math.Max(0, (int)Math.Ceiling((cooldownUntilUtc.Value - DateTime.UtcNow).TotalSeconds))
        : 0;

    private void TriggerMessageFadeIn(Guid messageId)
    {
        animatingMessageIds.Add(messageId);
        StateHasChanged();
        _ = Task.Delay(500).ContinueWith(_ =>
        {
            animatingMessageIds.Remove(messageId);
            InvokeAsync(StateHasChanged);
        });
    }

