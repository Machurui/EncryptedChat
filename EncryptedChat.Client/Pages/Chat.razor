    private bool _isSelectingTeam;

    private async Task SelectTeam(Guid teamId)
    {
        if (_isSelectingTeam) return;

        // Already selected: nothing to (re)load, but on mobile we still need to
        // flip back into the conversation pane. The Back button only hides it
        // (mobileShowConversation = false) without clearing selectedTeamId, so
        // tapping the same team again must re-show the conversation — without
        // this it looks like the click does nothing.
        if (selectedTeamId == teamId)
        {
            if (!mobileShowConversation)
            {
                mobileShowConversation = true;
                StateHasChanged();
            }
            return;
        }

        _isSelectingTeam = true;
        try
        {
            // Save scroll info of current team before switching
            if (selectedTeamId.HasValue)
            {
                var scrollInfo = await JS.InvokeAsync<ScrollInfo>("getScrollInfo", "messages-container");
                _teamScrollPositions[selectedTeamId.Value] = scrollInfo;
            }

            // Stop typing on previous team before switching
            if (isTyping && selectedTeamId.HasValue)
            {
                await StopTypingIndicator();
            }

            selectedTeamId = teamId;
            selectedTeam = teams.FirstOrDefault(t => t.Id == teamId);
            newMessageText = "";
            mobileShowConversation = true;
            showPinnedDropdown = false;
            pinnedMessages = new();

            if (selectedTeam == null) return;

            // E2E: load this team's TeamKeyShare rows + unwrap them into the
            // in-memory cache so SendMessageAsync / DecryptMessageAsync work
            // immediately. Idempotent.
            if (!string.IsNullOrEmpty(_userId))
            {
                await TeamClient.LoadKeySharesIntoCacheAsync(teamId, _userId);
            }

            // Check for unread BEFORE marking as read
            var hadUnread = GetUnreadCount(teamId) > 0;
            var isFirstVisit = !_visitedTeams.Contains(teamId);
            _visitedTeams.Add(teamId);
            MarkTeamAsRead(teamId);
            _ = TeamClient.MarkReadAsync(teamId); // fire-and-forget server sync

            await LoadTeamDetails();

            // Admin reconciliation: wrap the team key for any invited member
            // who doesn't have a key-share yet at this generation. Fire-and-forget;
            // idempotent; safe no-op for non-admins (server returns 403 → skipped).
            if (selectedTeam != null && IsCurrentUserAdmin)
            {
                _ = TeamClient.ProvisionMissingKeySharesAsync(selectedTeam.Id, selectedTeam.KeyGeneration);
            }

            // Scroll to bottom on first visit, first load, or if unread
            // Otherwise restore previous scroll position (or scroll to bottom if user was there)
            var shouldScrollToBottom = _isFirstLoad || isFirstVisit || hadUnread;
            double? restorePosition = null;

            if (!shouldScrollToBottom && _teamScrollPositions.TryGetValue(teamId, out var savedInfo))
            {
                if (savedInfo.IsAtBottom)
                {
                    shouldScrollToBottom = true;
                }
                else
                {
                    restorePosition = savedInfo.Position;
                }
            }

            // Disable auto-follow during load to avoid jank from the MutationObserver
            // scrolling to bottom while we're about to restore a saved position.
            await JS.InvokeVoidAsync("chatScroll.unfollow", "messages-container");

            await LoadMessages(scrollToBottom: shouldScrollToBottom);

            if (restorePosition.HasValue)
            {
                await JS.InvokeVoidAsync("setScrollPosition", "messages-container", restorePosition.Value);
                // The scroll handler will recompute the following state from isAtBottom.
            }
            else if (shouldScrollToBottom)
            {
                // Instant jump (no animation needed for team-switch initial position)
                await JS.InvokeVoidAsync("chatScroll.follow", "messages-container", false);
            }

            // Only initialize SignalR once
            if (!_signalRInitialized)
            {
                await InitializeSignalR();
            }

            if (selectedTeam != null && !string.IsNullOrEmpty(selectedTeam.UrlToken))
            {
                Navigation.NavigateTo($"/chat/c/{selectedTeam.UrlToken}", replace: true);
            }
        }
        finally
        {
            _isSelectingTeam = false;
        }
    }

    private async Task LoadTeamDetails()
    {
        if (!selectedTeamId.HasValue) return;

        membersState = LoadState.Loading;
        membersError = null;

        try
        {
            var result = await TeamClient.GetTeamDetailsAsync(selectedTeamId.Value);
            if (!result.Success)
            {
                membersState = LoadState.Error;
                membersError = result.ErrorMessage ?? "Failed to load team details.";
                return;
            }

            if (result.Value == null)
            {
                membersState = LoadState.Empty;
                return;
            }

            teamDetails = result.Value;
            isAdmin = teamDetails.Members?.Any(m => m.User?.Id == _userId && m.Role == "Admin") ?? false;
            membersState = (teamDetails.Members != null && teamDetails.Members.Any())
                ? LoadState.Success
                : LoadState.Empty;
        }
        catch (Exception ex)
        {
            membersState = LoadState.Error;
            membersError = ex.Message;
        }
    }

    private async Task LoadMessages(bool scrollToBottom = false)
    {
        if (!selectedTeamId.HasValue) return;

        messagesState = LoadState.Loading;
        messagesError = null;
        currentPage = 1;
        hasMoreMessages = true;

        try
        {
            var result = await ChatClient.GetMessagesByTeamAsync(
                selectedTeamId.Value, page: 1, pageSize: MessagesPageSize);
            if (!result.Success)
            {
                messagesState = LoadState.Error;
                messagesError = result.ErrorMessage ?? "Failed to load messages.";
                return;
            }

            var fetched = result.Value ?? [];
            messages = fetched.OrderBy(m => m.Date).ToList();
            teamMessages[selectedTeamId.Value] = messages;
            hasMoreMessages = fetched.Count == MessagesPageSize;
            messagesState = messages.Any() ? LoadState.Success : LoadState.Empty;

            // E2E: decrypt each message's envelope into DisplayText for the UI.
            // Failures stay null and the UI shows the placeholder shim.
            if (!string.IsNullOrEmpty(_userId))
            {
                foreach (var msg in messages)
                    await ChatClient.DecryptMessageAsync(msg, _userId);
            }

            // Load pinned messages alongside so we can highlight them in the messages list
            var pinsResult = await PinnedMessageClient.GetPinnedMessagesAsync(selectedTeamId.Value);
            if (pinsResult.Success)
            {
                pinnedMessages = pinsResult.Value ?? [];
                if (!string.IsNullOrEmpty(_userId))
                {
                    foreach (var pin in pinnedMessages)
                        if (pin.Message != null)
                            await ChatClient.DecryptMessageAsync(pin.Message, _userId);
                }
            }

            if (scrollToBottom)
            {
                _isFirstLoad = false;
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            messagesState = LoadState.Error;
            messagesError = ex.Message;
        }
    }

    private async Task LoadOlderMessages()
    {
        if (!selectedTeamId.HasValue || !hasMoreMessages || isLoadingOlderMessages)
            return;

        isLoadingOlderMessages = true;
        StateHasChanged();

        try
        {
            var scrollHeightBefore = await JS.InvokeAsync<double>("getScrollHeight", "messages-container");

            var nextPage = currentPage + 1;
            var result = await ChatClient.GetMessagesByTeamAsync(
                selectedTeamId.Value, page: nextPage, pageSize: MessagesPageSize);

            if (!result.Success)
            {
                return; // silent: retry on next scroll
            }

            var fetched = result.Value ?? [];
            if (fetched.Count == 0)
            {
                hasMoreMessages = false;
                return;
            }

            if (fetched.Count < MessagesPageSize)
                hasMoreMessages = false;

            var olderSorted = fetched.OrderBy(m => m.Date).ToList();

            // E2E: decrypt each older message's envelope into DisplayText
            // before they hit the UI. Without this the text shows empty
            // ("[encrypted]" via the shim); images would still render because
            // EncryptedImage does its own decrypt on mount.
            if (!string.IsNullOrEmpty(_userId))
            {
                foreach (var msg in olderSorted)
                    await ChatClient.DecryptMessageAsync(msg, _userId);
            }

            messages = olderSorted.Concat(messages).ToList();
            teamMessages[selectedTeamId.Value] = messages;
            currentPage = nextPage;

            StateHasChanged();

            await Task.Yield();
            await JS.InvokeVoidAsync("preserveScrollAfterPrepend",
                "messages-container", scrollHeightBefore);
        }
        finally
        {
            isLoadingOlderMessages = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task LoadOlderMessagesJs() => await LoadOlderMessages();

    private async Task InitializeSignalR()
    {
        // Skip if already initialized and connected
        if (_signalRInitialized && hubConnection?.State == HubConnectionState.Connected)
        {
            return;
        }

        // Dispose existing connection if reconnecting
        if (hubConnection != null)
        {
            try { await hubConnection.DisposeAsync(); } catch { }
        }

        try
        {
            var token = await AuthClient.GetSignalRTokenAsync();
            if (string.IsNullOrEmpty(token)) return;

            hubConnection = new HubConnectionBuilder()
                .WithUrl($"https://localhost:7294/hubs/chat?access_token={token}")
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<ChatClient.MessageDTOPublic>("ReceiveMessage", async message =>
            {
                // E2E: decrypt the envelope into DisplayText before storing so
                // the UI renders the plaintext. Failures leave DisplayText null;
                // the shim falls back to "[encrypted]" via the Text accessor.
                if (!string.IsNullOrEmpty(_userId))
                    await ChatClient.DecryptMessageAsync(message, _userId);

                // Sidebar preview: server can no longer fill TeamLastMessage
                // with plaintext (E2E). Inject the just-decrypted text into the
                // local cache so the team-row preview shows "name: hello" right
                // away instead of "name: ".
                if (!string.IsNullOrEmpty(message.Text))
                {
                    lastMessageUpdates[message.TeamId] = new TeamLastMessageInfo(
                        message.Text,
                        message.Date,
                        message.Sender?.Name);
                }

                // Store message (check for duplicates by Id)
                if (!teamMessages.ContainsKey(message.TeamId))
                    teamMessages[message.TeamId] = new();

                if (teamMessages[message.TeamId].Any(m => m.Id == message.Id))
                    return;

                // Add to cache (for non-current teams) or to messages (for current team)
                if (message.TeamId == selectedTeamId)
                {
                    if (!messages.Any(m => m.Id == message.Id))
                    {
                        messages.Add(message);
                        // First message in a previously empty DM/team: flip the
                        // LoadingState from Empty → Success so the foreach renders.
                        // Without this, the "No messages yet" template keeps showing
                        // until the user reloads.
                        if (messagesState != LoadState.Success)
                            messagesState = LoadState.Success;
                        TriggerMessageFadeIn(message.Id);
                        // chatScroll observer auto-handles re-scroll if user is at bottom.
                        await InvokeAsync(StateHasChanged);
                    }
                }
                else
                {
                    teamMessages[message.TeamId].Add(message);

                    var messageTeam = teams.FirstOrDefault(t => t.Id == message.TeamId);
                    var isDm = messageTeam?.IsDirect ?? false;
                    var isMentioned = MessageMentionsUser(message.Text);
                    var isOwn = message.Sender?.Id == _userId;
                    var isMuted = mutedTeams.Contains(message.TeamId);

                    // Badge = real unread, ALWAYS. Only guard against our own
                    // messages (e.g. sent from another device). Independent of
                    // notification preference and status.
                    if (!isOwn)
                    {
                        IncrementUnread(message.TeamId);
                    }

                    // Toast = preference + status + mute (see NotificationPolicy).
                    if (NotificationPolicy.ShouldShowToast(currentNotificationPreference, isDm, isMentioned, currentStatus, isOwn, isMuted))
                    {
                        var senderName = message.Sender?.Name ?? "Someone";
                        var notifTitle = isDm ? senderName : $"{senderName} in {messageTeam?.Name ?? "Team"}";
                        var text = message.Text?.Length > 50 ? message.Text[..50] + "..." : message.Text;
                        await JS.InvokeVoidAsync("showNotification", notifTitle, text ?? "New message");
                    }

                    await InvokeAsync(StateHasChanged);
                }
            });

            // Multi-device sync: the server broadcasts these to all of the user's
            // own connections (Clients.User) whenever they change settings/read/mute
            // on any device.
            hubConnection.On<SelfReadStateEvent>("SelfReadStateChanged", async evt =>
            {
                unreadCounts[evt.TeamId] = 0;
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<SelfMuteEvent>("SelfMuteChanged", async evt =>
            {
                if (evt.Muted) mutedTeams.Add(evt.TeamId);
                else mutedTeams.Remove(evt.TeamId);
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<SelfSettingsEvent>("SelfSettingsChanged", async evt =>
            {
                // While the profile modal is open the user is actively editing their
                // status / notification preference there — the modal's local selection
                // is the source of truth. Applying a (possibly stale) self-echo here
                // would clobber the in-progress edit mid-save: the echo overwrote
                // currentStatus AFTER the modal set it but BEFORE HandleProfileSave
                // built its DTO, so the save persisted the old status. Ignore echoes
                // until the modal closes (its own save echo reconciles afterwards).
                if (showProfileModal)
                {
                    return;
                }

                currentNotificationPreference = (evt.NotificationPreference ?? "all").ToLowerInvariant().Trim();
                if (!string.IsNullOrWhiteSpace(evt.Status))
                    currentStatus = evt.Status!;
                await NotifyStateChangedAsync();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<AttachmentAddedEvent>("AttachmentAdded", async evt =>
            {
                Console.WriteLine($"[SignalR] AttachmentAdded: MessageId={evt.MessageId}");

                // Find in current team messages
                var message = messages.FirstOrDefault(m => m.Id == evt.MessageId);
                if (message != null)
                {
                    message.Attachments ??= new List<AttachmentClient.AttachmentDTOPublic>();
                    if (!message.Attachments.Any(a => a.Id == evt.Attachment.Id))
                    {
                        message.Attachments.Add(evt.Attachment);
                        // chatScroll observer auto-handles re-scroll if user is at bottom.
                        await InvokeAsync(StateHasChanged);
                    }
                }

                // Also update in teamMessages cache
                foreach (var kvp in teamMessages)
                {
                    var cachedMessage = kvp.Value.FirstOrDefault(m => m.Id == evt.MessageId);
                    if (cachedMessage != null)
                    {
                        cachedMessage.Attachments ??= new List<AttachmentClient.AttachmentDTOPublic>();
                        if (!cachedMessage.Attachments.Any(a => a.Id == evt.Attachment.Id))
                        {
                            cachedMessage.Attachments.Add(evt.Attachment);
                        }
                    }
                }
            });

            hubConnection.On<FriendProfileUpdate>("FriendProfileUpdated", async update =>
            {
                Console.WriteLine($"[SignalR] FriendProfileUpdated received: id={update.Id}, NameColor={update.NameColor}, Name={update.Name}");

                // Update friend list
                var friend = friends.FirstOrDefault(f => f.UserId == update.Id);
                if (friend != null)
                {
                    var index = friends.IndexOf(friend);
                    friends[index] = friend with
                    {
                        Name = update.Name,
                        Handle = update.Handle,
                        NameColor = update.NameColor ?? friend.NameColor,
                        ProfileImageUrl = update.ProfileImageUrl,
                        Status = update.Status,
                        StatusMessage = update.StatusMessage,
                        LastSeenAt = update.LastSeenAt ?? friend.LastSeenAt
                    };
                }

                // Update team members if this user is in the current team
                if (teamDetails?.Members != null)
                {
                    var member = teamDetails.Members.FirstOrDefault(m => m.User?.Id == update.Id);
                    if (member?.User != null)
                    {
                        var updatedUser = member.User with
                        {
                            Name = update.Name,
                            Handle = update.Handle,
                            NameColor = update.NameColor ?? member.User.NameColor,
                            ProfileImageUrl = update.ProfileImageUrl
                        };
                        var idx = teamDetails.Members.ToList().IndexOf(member);
                        var membersList = teamDetails.Members.ToList();
                        membersList[idx] = member with { User = updatedUser };
                        teamDetails = teamDetails with { Members = membersList };
                    }
                }

                // Patch messages currently in view (MessageDTOPublic / SenderDTO are
                // mutable classes — mutate in place; Blazor's diff picks up the
                // new property values on the next render).
                foreach (var msg in messages)
                {
                    if (msg.Sender != null && msg.Sender.Id == update.Id)
                    {
                        msg.Sender.Name = update.Name;
                        msg.Sender.Handle = update.Handle;
                        msg.Sender.NameColor = update.NameColor ?? msg.Sender.NameColor;
                        msg.Sender.ProfileImageUrl = update.ProfileImageUrl;
                    }
                }

                // Patch the per-team message cache so other conversations also
                // reflect the new identity when the user switches back to them.
                foreach (var kvp in teamMessages)
                {
                    foreach (var msg in kvp.Value)
                    {
                        if (msg.Sender != null && msg.Sender.Id == update.Id)
                        {
                            msg.Sender.Name = update.Name;
                            msg.Sender.Handle = update.Handle;
                            msg.Sender.NameColor = update.NameColor ?? msg.Sender.NameColor;
                            msg.Sender.ProfileImageUrl = update.ProfileImageUrl;
                        }
                    }
                }

                // Patch pinned messages dropdown.
                foreach (var pin in pinnedMessages)
                {
                    if (pin.Message?.Sender != null && pin.Message.Sender.Id == update.Id)
                    {
                        pin.Message.Sender.Name = update.Name;
                        pin.Message.Sender.Handle = update.Handle;
                        pin.Message.Sender.NameColor = update.NameColor ?? pin.Message.Sender.NameColor;
                        pin.Message.Sender.ProfileImageUrl = update.ProfileImageUrl;
                    }
                }

                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<Guid>("FriendRequestCancelled", async requestId =>
            {
                Console.WriteLine($"[SignalR] FriendRequestCancelled received: {requestId}");
                pendingRequests = pendingRequests.Where(r => r.RequestId != requestId).ToList();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<string>("FriendRemoved", async removedByUserId =>
            {
                Console.WriteLine($"[SignalR] FriendRemoved received: {removedByUserId}");
                friends = friends.Where(f => f.UserId != removedByUserId).ToList();
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<FriendClient.FriendRequestDTO>("FriendRequestReceived", async request =>
            {
                Console.WriteLine($"[SignalR] FriendRequestReceived: requestId={request.RequestId}, from={request.Name} ({request.UserId})");
                if (!pendingRequests.Any(r => r.RequestId == request.RequestId))
                {
                    pendingRequests.Add(request);
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<Guid, FriendClient.FriendDTO>("FriendRequestAccepted", async (requestId, newFriend) =>
            {
                Console.WriteLine($"[SignalR] FriendRequestAccepted: requestId={requestId}, friend={newFriend.Name} ({newFriend.UserId})");
                pendingRequests = pendingRequests.Where(r => r.RequestId != requestId).ToList();
                if (!friends.Any(f => f.UserId == newFriend.UserId))
                {
                    friends.Add(newFriend);
                    // First friend appended live: flip the LoadingState so the
                    // SuccessTemplate's foreach renders the new friend. Without
                    // this, friendsState stays Empty (set at load time when the
                    // requester had zero friends) and the panel keeps showing
                    // "No friends yet" until F5. Same pattern as the DM first-
                    // message fix.
                    if (friendsState != LoadState.Success)
                        friendsState = LoadState.Success;
                }
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<FriendProfileUpdate>("FriendRequestProfileUpdated", async update =>
            {
                Console.WriteLine($"[SignalR] FriendRequestProfileUpdated received: id={update.Id}, NameColor={update.NameColor}");
                var request = pendingRequests.FirstOrDefault(r => r.UserId == update.Id);
                if (request != null)
                {
                    var index = pendingRequests.IndexOf(request);
                    pendingRequests[index] = request with
                    {
                        Name = update.Name,
                        Handle = update.Handle,
                        NameColor = update.NameColor ?? request.NameColor,
                        ProfileImageUrl = update.ProfileImageUrl
                    };
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<TeamClient.TeamDTOPublic>("TeamCreated", async team =>
            {
                if (!teams.Any(t => t.Id == team.Id))
                {
                    teams.Add(team);
                    await hubConnection.InvokeAsync("JoinTeam", team.Id);
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<TeamClient.TeamDTOPublic>("TeamUpdated", async team =>
            {
                var index = teams.FindIndex(t => t.Id == team.Id);
                if (index >= 0)
                {
                    teams[index] = team;
                    if (selectedTeamId == team.Id)
                    {
                        selectedTeam = team;
                    }
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<TeamDeletedEvent>("TeamDeleted", async evt =>
            {
                var removed = teams.RemoveAll(t => t.Id == evt.TeamId);
                if (removed > 0)
                {
                    // Drop any cached state tied to the deleted team
                    teamMessages.Remove(evt.TeamId);
                    _teamScrollPositions.Remove(evt.TeamId);
                    _visitedTeams.Remove(evt.TeamId);

                    if (selectedTeamId == evt.TeamId)
                    {
                        // Reset current-team state BEFORE switching so the next
                        // SelectTeam call doesn't try to save scroll position for
                        // the now-deleted team, and the old conversation's
                        // messages don't bleed into the new view.
                        selectedTeamId = null;
                        selectedTeam = null;
                        messages.Clear();
                        pinnedMessages.Clear();

                        var nextTeam = teams.FirstOrDefault();
                        if (nextTeam != null)
                        {
                            await SelectTeam(nextTeam.Id);
                        }
                    }
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<TeamMemberEvent>("TeamMemberAdded", async evt =>
            {
                if (evt.UserId == _userId && evt.Team != null && !teams.Any(t => t.Id == evt.TeamId))
                {
                    teams.Add(evt.Team);
                    await hubConnection.InvokeAsync("JoinTeam", evt.TeamId);
                }
                else if (evt.TeamId == selectedTeamId && evt.Team != null)
                {
                    var index = teams.FindIndex(t => t.Id == evt.TeamId);
                    if (index >= 0)
                        teams[index] = evt.Team;
                    await LoadTeamDetails();
                }
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<TeamMemberRemovedEvent>("TeamMemberRemoved", async evt =>
            {
                if (evt.UserId == _userId)
                {
                    teams.RemoveAll(t => t.Id == evt.TeamId);
                    if (selectedTeamId == evt.TeamId)
                    {
                        selectedTeamId = teams.FirstOrDefault()?.Id;
                        selectedTeam = teams.FirstOrDefault();
                        if (selectedTeamId.HasValue)
                            await LoadTeamDetails();
                    }
                }
                else if (evt.TeamId == selectedTeamId)
                {
                    await LoadTeamDetails();
                }
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<TeamMemberRoleChangedEvent>("TeamMemberRoleChanged", async evt =>
            {
                // Update the member's role in-place so the manage modal and any
                // role-gated UI (admin-only buttons) reflect the change without
                // a full refetch. Only refresh teamDetails when this concerns
                // the currently-selected team — other teams will sync the next
                // time they're opened.
                if (evt.TeamId == selectedTeamId && teamDetails?.Members != null)
                {
                    var idx = teamDetails.Members.FindIndex(m => m.User?.Id == evt.UserId);
                    if (idx >= 0)
                    {
                        teamDetails.Members[idx] = teamDetails.Members[idx] with { Role = evt.NewRole };
                    }
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<MessagesExpiredEvent>("MessagesExpired", async evt =>
            {
                if (teamMessages.TryGetValue(evt.TeamId, out var messages))
                {
                    var expiredSet = evt.MessageIds.ToHashSet();
                    messages.RemoveAll(m => expiredSet.Contains(m.Id));
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<TeamLastMessageEvent>("TeamLastMessageUpdated", async evt =>
            {
                lastMessageUpdates[evt.TeamId] = new TeamLastMessageInfo(
                    evt.LastMessagePreview,
                    evt.LastMessageTime,
                    evt.LastMessageSenderName);

                var teamIndex = teams.FindIndex(t => t.Id == evt.TeamId);
                if (teamIndex >= 0)
                {
                    teams = teams.OrderByDescending(t =>
                        lastMessageUpdates.TryGetValue(t.Id, out var u) && u.Time.HasValue
                            ? u.Time.Value
                            : t.LastMessageTime ?? DateTime.MinValue).ToList();
                }
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<TeamClient.TeamDTOPublic>("DirectMessageCreated", async dm =>
            {
                Console.WriteLine($"[SignalR] DirectMessageCreated: {dm.Id} - {dm.Name}");
                // Add the DM to our teams list if not already there
                if (!teams.Any(t => t.Id == dm.Id))
                {
                    teams.Insert(0, dm);
                    // Join the SignalR group for this DM
                    await hubConnection.InvokeAsync("JoinTeam", dm.Id);
                }
                await InvokeAsync(StateHasChanged);
            });

            hubConnection.On<UserTypingEvent>("UserTyping", async evt =>
            {
                Console.WriteLine($"[SignalR] UserTyping received: TeamId={evt.TeamId}, UserId={evt.UserId}, UserName={evt.UserName}");

                if (!typingUsers.ContainsKey(evt.TeamId))
                    typingUsers[evt.TeamId] = new();

                var existing = typingUsers[evt.TeamId].FirstOrDefault(u => u.UserId == evt.UserId);
                if (existing != null)
                    typingUsers[evt.TeamId].Remove(existing);

                typingUsers[evt.TeamId].Add(new TypingUser(evt.UserId, evt.UserName, DateTime.UtcNow));
                Console.WriteLine($"[SignalR] UserTyping: Added to typingUsers, count now = {typingUsers[evt.TeamId].Count}");
                await InvokeAsync(StateHasChanged);

                _ = Task.Delay(5000).ContinueWith(async _ =>
                {
                    if (typingUsers.TryGetValue(evt.TeamId, out var users))
                    {
                        users.RemoveAll(u => u.UserId == evt.UserId && (DateTime.UtcNow - u.StartedAt).TotalSeconds > 4);
                        await InvokeAsync(StateHasChanged);
                    }
                });
            });

            hubConnection.On<UserStoppedTypingEvent>("UserStoppedTyping", async evt =>
            {
                if (typingUsers.TryGetValue(evt.TeamId, out var users))
                {
                    users.RemoveAll(u => u.UserId == evt.UserId);
                    await InvokeAsync(StateHasChanged);
                }
            });

            hubConnection.On<int>("RateLimited", retryAfterMs =>
            {
                OnRateLimited(retryAfterMs);
                return InvokeAsync(StateHasChanged);
            });

            hubConnection.On<TeamMemberStatusUpdate>("TeamMemberStatusChanged", update =>
            {
                if (teamDetails?.Members != null)
                {
                    var member = teamDetails.Members.FirstOrDefault(m => m.User?.Id == update.UserId);
                    if (member?.User != null)
                    {
                        var updatedUser = member.User with { Status = update.Status };
                        var idx = teamDetails.Members.ToList().IndexOf(member);
                        var membersList = teamDetails.Members.ToList();
                        membersList[idx] = member with { User = updatedUser };
                        teamDetails = teamDetails with { Members = membersList };
                        return InvokeAsync(StateHasChanged);
                    }
                }
                return Task.CompletedTask;
            });

            hubConnection.Reconnected += async (connectionId) =>
            {
                Console.WriteLine($"[SignalR] Reconnected: {connectionId} — re-syncing state");
                await RecoverFromOfflineAsync();
            };

            await hubConnection.StartAsync();
            Console.WriteLine($"[SignalR] Connected! ConnectionId={hubConnection.ConnectionId}");

            foreach (var team in teams)
            {
                Console.WriteLine($"[SignalR] Joining team: {team.Id} ({team.Name})");
                await hubConnection.InvokeAsync("JoinTeam", team.Id);
            }
            Console.WriteLine($"[SignalR] Joined {teams.Count} teams");

            _signalRInitialized = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SignalR] Failed: {ex.Message}");
            _signalRInitialized = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (showMentionDropdown && filteredMentions.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedMentionIndex = (selectedMentionIndex + 1) % filteredMentions.Count;
                return;
            }
            if (e.Key == "ArrowUp")
            {
                selectedMentionIndex = (selectedMentionIndex - 1 + filteredMentions.Count) % filteredMentions.Count;
                return;
            }
            if (e.Key == "Enter" || e.Key == "Tab")
            {
                InsertMention(filteredMentions[selectedMentionIndex]);
                return;
            }
            if (e.Key == "Escape")
            {
                CloseMentionDropdown();
                return;
            }
        }

        if (e.Key == "Enter" && !e.ShiftKey && !isSending)
        {
            await SendMessage();
        }
    }

    private async Task HandleMessageInput(ChangeEventArgs e)
    {
        newMessageText = e.Value?.ToString() ?? "";

        // Check for mention trigger
        CheckForMentionTrigger();

        if (!selectedTeamId.HasValue || hubConnection?.State != HubConnectionState.Connected)
            return;

        if (!currentTypingIndicators)
            return;

        bool hasText = !string.IsNullOrWhiteSpace(newMessageText);

        if (hasText)
        {
            var now = DateTime.UtcNow;
            if (!isTyping || (now - lastTypingTime).TotalSeconds > 2)
            {
                isTyping = true;
                lastTypingTime = now;
                Console.WriteLine($"[Typing] StartTyping for team {selectedTeamId.Value}");
                await hubConnection.InvokeAsync("StartTyping", selectedTeamId.Value);
                // Keep the receiver's indicator alive even when the composer
                // loses focus — as long as the input still has text, we
                // re-emit StartTyping on a heartbeat (the receiver auto-
                // expires after 5s without a new event).
                StartTypingHeartbeat();
            }
        }
        else if (isTyping)
        {
            Console.WriteLine($"[Typing] StopTyping (input cleared) for team {selectedTeamId.Value}");
            await StopTypingIndicator();
        }
    }

    private void StartTypingHeartbeat()
    {
        typingTimer?.Stop();
        typingTimer?.Dispose();
        typingTimer = new System.Timers.Timer(3000) { AutoReset = true };
        typingTimer.Elapsed += async (_, _) =>
        {
            if (!isTyping || !selectedTeamId.HasValue || hubConnection?.State != HubConnectionState.Connected)
                return;
            if (string.IsNullOrWhiteSpace(newMessageText))
                return;
            try
            {
                await hubConnection.InvokeAsync("StartTyping", selectedTeamId.Value);
            }
            catch
            {
                // Hub may have dropped between the state check and the call;
                // the receiver's 5s auto-expire will clean up.
            }
        };
        typingTimer.Start();
    }

    private void StopTypingHeartbeat()
    {
        typingTimer?.Stop();
        typingTimer?.Dispose();
        typingTimer = null;
    }

    private async Task StopTypingIndicator()
    {
        StopTypingHeartbeat();
        if (isTyping && selectedTeamId.HasValue && hubConnection?.State == HubConnectionState.Connected)
        {
            isTyping = false;
            await hubConnection.InvokeAsync("StopTyping", selectedTeamId.Value);
        }
    }

    private async Task HandleComposerBlur()
    {
        await Task.Delay(150); // Allow click on mention item
        CloseMentionDropdown();
        // Do NOT stop the typing indicator on blur — the user may have stepped
        // away briefly with text still in the composer, and we want the
        // receiver to keep seeing "X is typing…" while text is pending.
        // The heartbeat (re-emit every 3s while text present) keeps the
        // receiver's indicator alive; the indicator clears when the text is
        // sent, cleared, or the composer is disposed.
    }

    private void CheckForMentionTrigger()
    {
        if (string.IsNullOrEmpty(newMessageText) || teamDetails?.Members == null)
        {
            CloseMentionDropdown();
            return;
        }

        // Find the last @ that starts a mention
        int lastAtIndex = newMessageText.LastIndexOf('@');
        if (lastAtIndex == -1)
        {
            CloseMentionDropdown();
            return;
        }

        // Check if @ is at start or preceded by space (not in middle of word)
        if (lastAtIndex > 0 && newMessageText[lastAtIndex - 1] != ' ')
        {
            CloseMentionDropdown();
            return;
        }

        // Get the query after @
        string query = newMessageText[(lastAtIndex + 1)..];

        // If there's a space after the query start, the mention is complete
        if (query.Contains(' '))
        {
            CloseMentionDropdown();
            return;
        }

        mentionStartIndex = lastAtIndex;
        mentionQuery = query.ToLowerInvariant();

        // Filter members by handle only — consistent with mention rendering
        // (RenderMessageWithMentions chips only handle matches, not display names).
        filteredMentions = teamDetails.Members
            .Where(m => m.User != null && m.User.Id != _userId)
            .Where(m => m.User!.Handle?.ToLowerInvariant().Contains(mentionQuery) ?? false)
            .Take(5)
            .ToList();

        if (filteredMentions.Any())
        {
            showMentionDropdown = true;
            selectedMentionIndex = 0;
        }
        else
        {
            CloseMentionDropdown();
        }
    }

    private void InsertMention(TeamClient.MemberDTOPublic member)
    {
        if (member.User == null || mentionStartIndex < 0) return;

        string mentionText = !string.IsNullOrEmpty(member.User.Handle)
            ? $"@{member.User.Handle}"
            : $"@{member.User.Name}";

        // Replace the @query with the full mention
        newMessageText = newMessageText[..mentionStartIndex] + mentionText + " ";
        CloseMentionDropdown();
    }

    private void CloseMentionDropdown()
    {
        showMentionDropdown = false;
        mentionQuery = "";
        mentionStartIndex = -1;
        selectedMentionIndex = 0;
        filteredMentions.Clear();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(newMessageText) && selectedFile == null) return;
        if (!selectedTeamId.HasValue) return;

        isSending = true;
        try
        {
            await StopTypingIndicator();

            // E2E: encrypt + sign client-side and POST via REST. The server
            // never sees plaintext.
            int teamGen = selectedTeam?.KeyGeneration ?? 1;

            // If we have an attachment, send the message first then the file
            if (selectedFile != null)
            {
                var messageText = newMessageText?.Trim() ?? "";
                var result = await ChatClient.SendMessageAsync(selectedTeamId.Value, messageText, teamGen, _userId!);

                if (result.RateLimited)
                {
                    OnRateLimited(result.RetryAfterMs);
                    return;
                }

                if (result.Success && result.Value != null)
                {
                    var messageId = result.Value.Id;
                    var fileName = selectedFile.Name;
                    var contentType = selectedFile.ContentType ?? "application/octet-stream";

                    using var stream = selectedFile.OpenReadStream(maxAllowedSize: 26_214_400);
                    using var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);
                    await AttachmentClient.UploadAsync(selectedTeamId.Value, messageId, teamGen, _userId!, fileName, contentType, ms.ToArray());

                    // Optimistic local render: the SendMessageAsync result already
                    // carries DisplayText (set client-side), so the message shows
                    // its plaintext immediately while the ReceiveMessage broadcast
                    // will dedup by Id.
                    if (result.Value.TeamId == selectedTeamId && !messages.Any(m => m.Id == result.Value.Id))
                    {
                        messages.Add(result.Value);
                        if (messagesState != LoadState.Success)
                            messagesState = LoadState.Success;
                        TriggerMessageFadeIn(result.Value.Id);
                    }

                    selectedFile = null;
                }

                newMessageText = string.Empty;
            }
            else
            {
                _lastAttemptedSendText = newMessageText;
                var result = await ChatClient.SendMessageAsync(selectedTeamId.Value, newMessageText, teamGen, _userId!);

                if (result.RateLimited)
                {
                    OnRateLimited(result.RetryAfterMs);
                    return;
                }

                if (result.Success && result.Value != null && result.Value.TeamId == selectedTeamId &&
                    !messages.Any(m => m.Id == result.Value.Id))
                {
                    messages.Add(result.Value);
                    if (messagesState != LoadState.Success)
                        messagesState = LoadState.Success;
                    TriggerMessageFadeIn(result.Value.Id);

                    // Update the sidebar preview locally — server can't fill it (E2E),
                    // and ReceiveMessage may not echo back to the sender quickly.
                    if (!string.IsNullOrEmpty(result.Value.Text))
                    {
                        lastMessageUpdates[result.Value.TeamId] = new TeamLastMessageInfo(
                            result.Value.Text,
                            result.Value.Date,
                            result.Value.Sender?.Name);
                    }
                }

                // Only clear if not rate-limited. If RateLimited event arrived during the
                // await, IsInCooldown is already true and we preserve the user's text.
                if (!IsInCooldown)
                {
                    newMessageText = string.Empty;
                }
            }
        }
        finally
        {
            isSending = false;
            await FocusComposerInput();
            // Sending your own message → re-enable follow and smooth-scroll to bottom.
            // The chatScroll observer will continue to keep things glued to the bottom as
            // any attachment / image / GIF finishes loading.
            try
            {
                await JS.InvokeVoidAsync("chatScroll.follow", "messages-container", true);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"chatScroll.follow (SendMessage) failed: {ex.Message}");
            }
            // Collapse the textarea back to one row after a clear. The JS
            // input listener only runs on user input; a C# value reset alone
            // leaves stale style.height inherited from the multi-line content
            // we just sent.
            try { await JS.InvokeVoidAsync("composerOverlay.resize", "composer-input"); } catch { }
        }
    }

