    private static bool IsImageMimeType(string? mimeType)
    {
        if (string.IsNullOrEmpty(mimeType)) return false;
        return mimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
    }

    private bool MessageMentionsUser(string? text)
    {
        if (string.IsNullOrEmpty(text)) return false;

        var mentionPattern = new System.Text.RegularExpressions.Regex(@"@(\w+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        var matches = mentionPattern.Matches(text);

        foreach (System.Text.RegularExpressions.Match match in matches)
        {
            var handle = match.Groups[1].Value.ToLowerInvariant();
            if (handle == currentUserHandle?.ToLowerInvariant())
            {
                return true;
            }
        }
        return false;
    }

    public async ValueTask DisposeAsync()
    {
        _cooldownTickTimer?.Stop();
        _cooldownTickTimer?.Dispose();
        _cooldownTickTimer = null;

        typingTimer?.Stop();
        typingTimer?.Dispose();
        typingTimer = null;

        if (_popupListenerRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("popupRegistry.unregister", "chat-popups");
            }
            catch
            {
                // JS context might already be gone (page unload)
            }
            _popupListenerRegistered = false;
        }
        _dotNetRef?.Dispose();
        _dotNetRef = null;

        try
        {
            await JS.InvokeVoidAsync("chatScroll.detach", "messages-container");
        }
        catch
        {
            // JS context might already be gone
        }

        _signalRInitialized = false;
        if (hubConnection != null)
        {
            try
            {
                if (selectedTeamId.HasValue)
                    await hubConnection.InvokeAsync("LeaveTeam", selectedTeamId);
                await hubConnection.DisposeAsync();
            }
            catch { }
        }

        if (gifPickerDotNetRef != null)
        {
            try
            {
                await JS.InvokeVoidAsync("gifPicker.stopObserving", gifLoadSentinelRef);
            }
            catch { /* silent */ }
            gifPickerDotNetRef.Dispose();
            gifPickerDotNetRef = null;
        }
    }
