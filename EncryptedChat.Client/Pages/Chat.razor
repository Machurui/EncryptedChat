    private async Task LoadTrendingPage(int offset)
    {
        if (offset == 0)
        {
            isLoadingGifs = true;
            gifOffset = 0;
            gifHasMore = true;
            randomPreviewGif = null;
        }
        else
        {
            isLoadingMoreGifs = true;
        }
        StateHasChanged();

        try
        {
            var page = await GifClient.TrendingAsync(20, offset, stickers: Stickers);
            if (offset == 0)
                gifResults = page.Select(p => new GifResult(p.Url, p.PreviewUrl, p.Width, p.Height)).ToList();
            else
                gifResults.AddRange(page.Select(p => new GifResult(p.Url, p.PreviewUrl, p.Width, p.Height)));

            gifOffset = offset + page.Count;
            if (page.Count < 20) gifHasMore = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Trending load error: {ex.Message}");
            if (offset == 0) gifResults.Clear();
        }
        finally
        {
            isLoadingGifs = false;
            isLoadingMoreGifs = false;
            StateHasChanged();
        }
    }

