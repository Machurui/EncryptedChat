    private async Task InsertEmoji(string emoji)
    {
        // Insert at caret rather than appending to end. The textarea may have
        // multiple lines; "end" would put the emoji at the bottom-right glyph
        // of whatever's already typed, which surprises users mid-edit.
        int caret;
        try { caret = await JS.InvokeAsync<int>("composerOverlay.getCursorPos", "composer-input"); }
        catch { caret = newMessageText.Length; }
        if (caret < 0 || caret > newMessageText.Length) caret = newMessageText.Length;

        newMessageText = newMessageText.Insert(caret, emoji);
        showEmojiPicker = false;
        emojiSearch = "";
        // Atomic focus + caret placement — bypasses the racy multi-step
        // FocusComposerInput which would otherwise drop the caret at 0.
        try { await JS.InvokeVoidAsync("composerOverlay.focusAndSetCursor", "composer-input", caret + emoji.Length); } catch { }
        try { await JS.InvokeVoidAsync("composerOverlay.resize", "composer-input"); } catch { }
    }

