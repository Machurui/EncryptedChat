    private string GetTeamInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private string GetTeamColor(string name)
    {
        var hue = GetTeamHue(name);
        return $"oklch(0.55 0.14 {hue})";
    }

    private int GetTeamHue(string name)
    {
        var hash = name.GetHashCode();
        return Math.Abs(hash % 360);
    }

    private string GetSecondaryColor(string color)
    {
        var hueMatch = System.Text.RegularExpressions.Regex.Match(color, @"(\d+)\)");
        if (hueMatch.Success && int.TryParse(hueMatch.Groups[1].Value, out int hue))
        {
            return $"oklch(0.42 0.14 {(hue + 60) % 360})";
        }
        return "oklch(0.42 0.14 195)";
    }

    private string GetLastActiveTime(Guid teamId)
    {
        DateTime? lastTime = null;

        if (lastMessageUpdates.TryGetValue(teamId, out var update) && update.Time.HasValue)
        {
            lastTime = update.Time;
        }
        else if (teamMessages.TryGetValue(teamId, out var msgs) && msgs.Any())
        {
            lastTime = msgs.Last().Date;
        }
        else
        {
            var team = teams.FirstOrDefault(t => t.Id == teamId);
            if (team?.LastMessageTime.HasValue == true)
                lastTime = team.LastMessageTime;
        }

        if (!lastTime.HasValue) return "";

        var diff = DateTime.UtcNow - lastTime.Value;
        if (diff.TotalMinutes < 1) return "now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h";
        return lastTime.Value.ToLocalTime().ToString("MMM d");
    }

    private string GetLastMessagePreview(Guid teamId)
    {
        // E2E: the server can no longer read message plaintext, so it
        // broadcasts TeamLastMessageUpdated with an EMPTY preview ("" not
        // null). Treat empty the same as missing so we fall through to the
        // teamMessages cache (populated client-side from decrypted blobs).
        if (lastMessageUpdates.TryGetValue(teamId, out var update) && !string.IsNullOrEmpty(update.Preview))
        {
            var who = update.SenderName?.Split(' ')[0] ?? "Someone";
            var text = update.Preview.Length > 30 ? update.Preview[..30] + "..." : update.Preview;
            return $"{who}: {text}";
        }

        if (teamMessages.TryGetValue(teamId, out var msgs) && msgs.Any())
        {
            var last = msgs.Last();
            var who = last.Sender?.Id == _userId ? "You" : (last.Sender?.Name?.Split(' ')[0] ?? "Someone");
            var text = (last.Text ?? "").Replace("\n", " ").Trim();

            if (string.IsNullOrWhiteSpace(text) && last.Attachments?.Any() == true)
            {
                var att = last.Attachments.First();
                var isImage = att.MimeType?.StartsWith("image/") == true;
                text = isImage ? "a envoyé une photo" : "a envoyé un fichier";
                return $"{who} {text}";
            }

            if (text.Length > 30) text = text[..30] + "...";
            return $"{who}: {text}";
        }

        var team = teams.FirstOrDefault(t => t.Id == teamId);
        if (team?.LastMessagePreview != null)
        {
            var who = team.LastMessageSenderName?.Split(' ')[0] ?? "Someone";
            return $"{who}: {team.LastMessagePreview}";
        }

        return "No messages yet";
    }

