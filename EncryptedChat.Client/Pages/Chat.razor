    private async Task CreateTeam()
    {
        if (string.IsNullOrWhiteSpace(newTeamName))
        {
            newTeamError = "Team name is required.";
            return;
        }

        isCreatingTeam = true;
        newTeamError = null;

        try
        {
            var result = await TeamClient.AddTeamAsync(
                _userId!,
                new[] { _userId! },
                Array.Empty<string>(),
                newTeamName.Trim());

            if (result.Success && result.Value != null)
            {
                showNewTeamModal = false;
                await LoadTeams();

                // Join the SignalR group for the new team so we receive
                // ReceiveMessage broadcasts. Same reason as HandleCreateTeam.
                if (hubConnection?.State == HubConnectionState.Connected)
                {
                    try { await hubConnection.InvokeAsync("JoinTeam", result.Value.Id); }
                    catch { /* silent */ }
                }

                if (teams.Any())
                {
                    var newTeam = teams.FirstOrDefault(t => t.Id == result.Value.Id);
                    if (newTeam != null)
                        await SelectTeam(newTeam.Id);
                }
            }
            else
            {
                newTeamError = result.ErrorMessage ?? "Failed to create team.";
            }
        }
        finally
        {
            isCreatingTeam = false;
        }
    }

    private async Task HandleCreateTeam((string Name, string Glyph, string Color, List<string> Members, string MessageLifetime) teamData)
    {
        var result = await TeamClient.AddTeamAsync(
            _userId!,
            new[] { _userId! },
            teamData.Members.ToArray(),
            teamData.Name,
            teamData.Glyph,
            teamData.Color,
            teamData.MessageLifetime);

        if (result.Success && result.Value != null)
        {
            // Refetch the teams list — the server returns a TeamDTOPublic that
            // lacks the caller's per-membership Role + LastMessage fields that
            // /api/user/me/teams populates, so the just-created team would
            // render incomplete if we just append result.Value. LoadTeams() is
            // idempotent w.r.t. the SignalR "TeamCreated" broadcast that also
            // fires asynchronously.
            await LoadTeams();

            // Join the SignalR group for the new team so we receive future
            // ReceiveMessage broadcasts for this team in real time. The
            // TeamCreated broadcast handler also calls JoinTeam, but it skips
            // when the team already exists locally (LoadTeams added it above),
            // so we must explicitly join here.
            if (hubConnection?.State == HubConnectionState.Connected)
            {
                try { await hubConnection.InvokeAsync("JoinTeam", result.Value.Id); }
                catch { /* silent — reconnect will retry */ }
            }

            await SelectTeam(result.Value.Id);
        }
    }

