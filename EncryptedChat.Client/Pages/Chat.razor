    private async Task AddTeamMember(string userId)
    {
        memberError = null;
        if (!selectedTeamId.HasValue) return;

        // 1. Add the member server-side (creates the Member row).
        var addResult = await TeamClient.AddMemberAsync(selectedTeamId.Value, userId);
        if (!addResult.Success)
        {
            memberError = addResult.ErrorMessage;
            return;
        }

        // 2. Upload the new member's wrapped TeamKeyShare. Without this, the
        //    new member's local cache stays empty → they can't decrypt or send.
        //    Same fundamental bug we fixed for DMs and team creation.
        int generation = selectedTeam?.KeyGeneration ?? 1;
        try
        {
            bool keyShareOk = await TeamClient.AddMemberKeyShareAsync(selectedTeamId.Value, generation, userId);
            if (!keyShareOk)
            {
                memberError = "Member added but failed to provision their encryption key. They may need to re-bootstrap.";
            }
        }
        catch (KeyChangedException ex)
        {
            memberError = "This member's safety number changed — key sharing was refused. Verify their safety number, then trust the new key.";
            var changedName = teamDetails?.Members?.FirstOrDefault(m => m.User?.Id == ex.UserId)?.User?.Name ?? "this member";
            OpenSafety(ex.UserId, changedName);
        }

        await LoadTeamDetails();
    }

