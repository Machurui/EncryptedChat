    private string GetDmDisplayName(TeamClient.TeamDTOPublic dm)
    {
        // For DMs, extract the other person's name from "User1 & User2"
        if (dm.Name.Contains(" & "))
        {
            var parts = dm.Name.Split(" & ");
            foreach (var part in parts)
            {
                if (part.Trim() != currentUserName)
                    return part.Trim();
            }
        }
        return dm.Name;
    }

    private async Task StartDirectMessage(string friendId)
    {
        Console.WriteLine($"[StartDirectMessage] friendId={friendId}, _userId={_userId ?? "NULL"}");
        if (string.IsNullOrEmpty(_userId))
        {
            Console.WriteLine("[StartDirectMessage] aborted: _userId is empty");
            return;
        }
        var result = await TeamClient.GetOrCreateDirectMessageAsync(_userId, friendId);
        Console.WriteLine($"[StartDirectMessage] result.Success={result.Success}, error={result.ErrorMessage ?? "<none>"}, value={(result.Value == null ? "NULL" : result.Value.Id.ToString())}");
        if (!result.Success && result.ErrorMessage?.StartsWith("KEY_CHANGED:") == true)
        {
            var changedId = result.ErrorMessage["KEY_CHANGED:".Length..];
            var changedName = friends.FirstOrDefault(f => f.UserId == changedId)?.Name ?? "this contact";
            OpenSafety(changedId, changedName);
            return;
        }
        if (result.Success && result.Value != null)
        {
            if (!teams.Any(t => t.Id == result.Value.Id))
            {
                teams.Add(result.Value);
            }

            // Sender must join the SignalR group for this DM so they receive their
            // own broadcasts when sending messages (server broadcasts ReceiveMessage
            // to the team-{dmId} group).
            try
            {
                if (hubConnection?.State == HubConnectionState.Connected)
                {
                    await hubConnection.InvokeAsync("JoinTeam", result.Value.Id);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[StartDirectMessage] JoinTeam failed: {ex.Message}");
            }

            await SelectTeam(result.Value.Id);
            activeNav = "chats";
        }
    }

