        try
        {
            if (!string.IsNullOrEmpty(_userId) && !await KeyVault.IsBootstrappedAsync(_userId))
            {
                showKeyBootstrap = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Chat] key-bootstrap check failed: {ex.Message}");
        }

        await LoadUserStatus();
        await LoadTeams();
        await LoadFriends();

        // SignalR must init even when the user has zero teams — otherwise new
        // users never receive FriendRequestReceived / FriendRequestAccepted /
        // FriendRequestCancelled / FriendRemoved broadcasts (they're routed via
        // Clients.User, not team groups, so they don't depend on JoinTeam).
        if (!_signalRInitialized)
        {
            await InitializeSignalR();
        }

        // Auto-select the first team only when the layout can fit both panels
        // side-by-side. On mobile (≤ 767px) selecting a team flips into the
        // single-pane conversation view, hiding the sidebar — landing users
        // there forces an extra back-tap just to see their team list. Match
        // the standard mobile chat-app UX: land on the list, tap to enter.
        int viewportWidth = 0;
        try { viewportWidth = await JS.InvokeAsync<int>("getViewportWidth"); } catch { viewportWidth = 1024; /* assume desktop on failure */ }
        if (teams.Any() && viewportWidth > 767)
        {
            await SelectTeam(teams.First().Id);
        }

        // Fire-and-forget: prewarm the GIF picker so first open is instant.
        // Server caches trending+categories; browser caches the thumbnails.
        _ = PrewarmGifPicker();
    }

    private async Task PrewarmGifPicker()
