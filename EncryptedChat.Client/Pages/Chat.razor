    private static readonly System.Text.RegularExpressions.Regex PureGifUrlRegex =
        new(@"^\s*https?://[^\s]+\.gif[^\s]*\s*$", System.Text.RegularExpressions.RegexOptions.IgnoreCase);

    private bool IsPureGifUrl(string? text) =>
        !string.IsNullOrWhiteSpace(text) && PureGifUrlRegex.IsMatch(text);

    private string RenderComposerHighlight(string? text)
    {
        if (string.IsNullOrEmpty(text))
            return string.Empty;

        var sb = new System.Text.StringBuilder();
        int i = 0;
        while (i < text.Length)
        {
            char c = text[i];
            bool atMention = c == '@' && (i == 0 || char.IsWhiteSpace(text[i - 1]));
            if (atMention)
            {
                int end = i + 1;
                while (end < text.Length && !char.IsWhiteSpace(text[end]))
                    end++;
                sb.Append("<span class=\"mention-token\">");
                sb.Append(System.Net.WebUtility.HtmlEncode(text[i..end]));
                sb.Append("</span>");
                i = end;
            }
            else
            {
                // Emojis are UTF-16 surrogate pairs (2 chars). Encode the
                // pair as one unit so the resulting HTML carries a valid
                // codepoint instead of two lone-surrogate "?" glyphs.
                if (char.IsHighSurrogate(c) && i + 1 < text.Length && char.IsLowSurrogate(text[i + 1]))
                {
                    sb.Append(System.Net.WebUtility.HtmlEncode(text.Substring(i, 2)));
                    i += 2;
                }
                else
                {
                    sb.Append(System.Net.WebUtility.HtmlEncode(c.ToString()));
                    i++;
                }
            }
        }
        return sb.ToString();
    }

    private string RenderMessageContent(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";

        // Pure-GIF-URL messages are rendered without a bubble by the markup path —
        // this method only runs for messages that have text content (possibly with inline GIFs).
        return RenderMessageWithMentions(text);
    }

    private string RenderMessageWithMentions(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";

        // Escape HTML first
        text = System.Net.WebUtility.HtmlEncode(text);

        // Find GIF URLs inline and render them
        var inlineGifPattern = new System.Text.RegularExpressions.Regex(@"(https?://[^\s]+\.gif[^\s]*)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        text = inlineGifPattern.Replace(text, match =>
        {
            var url = match.Groups[1].Value;
            return $"<img src=\"{url}\" alt=\"GIF\" class=\"message-gif-inline\" loading=\"lazy\" />";
        });

        // Find @mentions and highlight them, but only if they map to a real
        // team member (handle or normalized name). Otherwise leave as plain
        // text — avoids chipping arbitrary @word tokens like @testtest.
        var mentionPattern = new System.Text.RegularExpressions.Regex(@"@(\w+)");
        text = mentionPattern.Replace(text, match =>
        {
            var handle = match.Groups[1].Value.ToLowerInvariant();

            bool isCurrentUser = handle == currentUserHandle?.ToLowerInvariant();

            bool isMember = isCurrentUser || (teamDetails?.Members?.Any(m =>
                m.User != null &&
                m.User.Handle?.ToLowerInvariant() == handle) ?? false);

            if (!isMember)
                return match.Value;

            var cssClass = isCurrentUser ? "mention mention-me" : "mention";
            return $"<span class=\"{cssClass}\">{match.Value}</span>";
        });

        return text;
    }

