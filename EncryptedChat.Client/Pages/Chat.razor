    private async Task ToggleMute(Guid teamId)
    {
        bool newMuted = !mutedTeams.Contains(teamId);
        if (newMuted) mutedTeams.Add(teamId);
        else mutedTeams.Remove(teamId);
        StateHasChanged();

        bool ok = await TeamClient.SetMutedAsync(teamId, newMuted);
        if (!ok)
        {
            // Revert optimistic change on failure.
            if (newMuted) mutedTeams.Remove(teamId);
            else mutedTeams.Add(teamId);
            StateHasChanged();
        }
    }

