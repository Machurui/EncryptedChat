    /* ── Tablet (768 - 1023px) ── */
    @@media (min-width: 768px) and (max-width: 1023px) {
        .chat-sidebar-panel { width: 270px; }

        .members-rail-panel {
            position: fixed;
            right: 0;
            top: 0;
            bottom: 0;
            width: 280px;
            z-index: 100;
            box-shadow: -10px 0 40px rgba(0, 0, 0, 0.3);
