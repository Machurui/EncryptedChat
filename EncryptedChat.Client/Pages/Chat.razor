    {
        if (string.IsNullOrEmpty(currentUserName)) profileState = LoadState.Loading;
        profileError = null;

        try
        {
            var result = await UserClient.GetProfileAsync();
            if (!result.Success || result.Value == null)
            {
                profileState = LoadState.Error;
                profileError = result.ErrorMessage ?? "Failed to load profile.";
