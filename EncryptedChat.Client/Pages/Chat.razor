    // chat-header picker (userBubbleColors), so both UIs reflect the change
    // instantly without explicit re-sync.
    private async Task HandleBubbleColorFromModal(string color)
    {
        if (!selectedTeamId.HasValue || string.IsNullOrWhiteSpace(color)) return;
        userBubbleColors[selectedTeamId.Value] = color;
        // Repaint bubbles immediately via the CSS variable, bypassing Blazor
        // re-render of the 5000-line Chat.razor for smooth drag.
        try { await JS.InvokeVoidAsync("setBubbleColorPreview", color); } catch { }
        StateHasChanged();
        // Persist server-side fire-and-forget; the optimistic update wins in
        // the UI even if the request is in flight.
        _ = BubbleColorClient.SetBubbleColorAsync(selectedTeamId.Value, color);
    }

