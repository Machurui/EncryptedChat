        animation: fade-in-message 250ms ease-out;
    }

    @@media (prefers-reduced-motion: reduce) {
        .message.fade-in {
            animation: none;
        }
    }

    /* ── Mobile (max-width: 767px) ── */
    @@media (max-width: 767px) {
        .chat-floating-layout {
            padding: 0;
            gap: 0;
            position: fixed;
            inset: 0;
            height: 100vh;
            height: 100dvh;
            width: 100vw;
        }

        .chat-sidebar-panel,
        .conversation-column,
        .members-rail-panel { border-radius: 0; }

        /* Chat header: tighten padding + let the title shrink with ellipsis
           so the action buttons on the right never get clipped. */
        .conversation-header {
            padding: 12px 12px;
            gap: 8px;
        }

        .conversation-header-left {
            flex: 1 1 auto;
            min-width: 0;
        }

        /* Inner title block must also be shrinkable so its children (title-row
           + meta) can ellipsis instead of pushing buttons off the screen. */
        .conversation-header-left > div {
            flex: 1 1 auto;
            min-width: 0;
        }

        .conversation-title-row {
            min-width: 0;
        }

        .conversation-title {
            flex: 1 1 auto;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .conversation-meta {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Hide the E2EE pill on mobile — the app is fully E2EE so the pill
           is informational redundancy that eats badly needed horizontal space. */
        .e2ee-badge {
            display: none;
        }

        .conversation-header-right {
            flex: 0 0 auto;
            gap: 2px;
        }

        .conversation-header-right .icon-btn {
            width: 32px;
            height: 32px;
        }

        /* Consolidate everything in the More (⋯) menu on mobile.
           The direct action icons are hidden; their wrappers stay in DOM so
           the Bubble color and Pinned popovers (anchored to those wrappers)
           still render — they're CSS-relocated to a bottom-sheet below. */
        .conversation-header-right .mobile-hide-direct {
            display: none;
        }

        .mobile-only-item {
            display: flex;
        }

        /* Bubble color and Pinned popovers normally anchor to their (now
           hidden) trigger button. On mobile, sit under the chat header
           rather than at the absolute viewport top — the header stays
           visible/usable, and the dropdown doesn't compete with the
           keyboard / composer at the bottom. Offset ≈ header height
           (~70px) + small gap, plus safe-area for notch devices. */
        .header-dropdown.chat-bubble-color-dropdown,
        .header-dropdown.pinned-dropdown {
            position: fixed;
            top: calc(env(safe-area-inset-top, 0) + 76px);
            right: 12px;
            left: 12px;
            bottom: auto;
            max-width: none;
            min-width: 0;
            max-height: calc(100dvh - env(safe-area-inset-top, 0) - 96px);
            overflow-y: auto;
            z-index: 200;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.45);
        }

        /* Mobile back to sidebar: selectedTeamId stays set (so re-tapping the
           same team is cheap), but the row should NOT look active anymore
           because we're no longer "in" that conversation visually. Reset the
           active styling when the layout isn't showing the conversation. */
        .chat-floating-layout:not(.mobile-show-conversation) .team-row.active {
            background: transparent;
            box-shadow: none;
        }

        .chat-floating-layout .chat-sidebar-panel { display: flex; flex: 1; }
        .chat-floating-layout .conversation-column { display: none; }

        .chat-floating-layout.mobile-show-conversation .chat-sidebar-panel { display: none; }
        .chat-floating-layout.mobile-show-conversation .conversation-column {
            display: flex;
            flex: 1;
        }

        .chat-floating-layout.mobile-show-conversation .members-rail-panel {
            display: flex;
            position: fixed;
            inset: 0 0 0 auto;
            width: 85vw;
            z-index: 100;
            box-shadow: -10px 0 40px rgba(0, 0, 0, 0.3);
        }

        .composer-wrapper {
            position: sticky;
            bottom: 0;
            background: inherit;
            padding-bottom: env(safe-area-inset-bottom, 0);
            z-index: 5;
        }

        .composer-input {
            font-size: 16px;
            /* Tighter cap on mobile — 144px takes up too much vertical real
               estate when the on-screen keyboard is open. ~4 lines of 16px
               text fits in 96px. */
            max-height: 96px;
        }

        /* Composer 36×36 is enforced by the base .composer .icon-btn /
           .composer .send-btn rule above (which sets min-width / min-height
           too), so no additional override is needed for mobile. */

        /* Emoji/GIF pickers : center on mobile, max-width viewport */
        .emoji-picker,
        .gif-picker {
            position: fixed !important;
            bottom: 80px !important;
            left: 8px !important;
            right: 8px !important;
            top: auto !important;
            width: auto !important;
            height: 60vh !important;
            max-width: calc(100vw - 16px) !important;
            max-height: calc(100vh - 100px) !important;
            margin: 0 auto !important;
        }

        .jump-to-bottom-btn {
            bottom: 76px;
            right: 12px;
        }
    }
