    private static string SafeBubbleHex(string? color)
    {
        if (!string.IsNullOrWhiteSpace(color) && color.StartsWith('#') && color.Length == 7)
            return color;
        return "#a3e635";
    }

    // Extract hue 0-360 from a CSS color so the rainbow slider reflects it.
    // Accepts oklch(...), hex, rgb()/rgba(), or hsl()/hsla(). Defaults to 165
    // (teal — matches the global accent) when parsing fails.
    private static int GetBubbleHue(string? color)
    {
        if (string.IsNullOrWhiteSpace(color)) return 165;

        var trimmed = color.Trim();

        // oklch(L C H) — third number is the hue.
        if (trimmed.StartsWith("oklch(", StringComparison.OrdinalIgnoreCase))
        {
            var inside = trimmed[6..].TrimEnd(')');
            var parts = inside.Split(new[] { ' ', ',', '/' }, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 3 && double.TryParse(parts[2],
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out var h))
            {
                return ((int)Math.Round(h) % 360 + 360) % 360;
            }
        }

        // hsl(H ...) / hsla(H ...) — first number is the hue.
        if (trimmed.StartsWith("hsl", StringComparison.OrdinalIgnoreCase))
        {
            var open = trimmed.IndexOf('(');
            if (open >= 0)
            {
                var inside = trimmed[(open + 1)..].TrimEnd(')');
                var parts = inside.Split(new[] { ' ', ',', '/' }, StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length >= 1 && double.TryParse(parts[0].TrimEnd('°'),
                    System.Globalization.NumberStyles.Float,
                    System.Globalization.CultureInfo.InvariantCulture, out var h))
                {
                    return ((int)Math.Round(h) % 360 + 360) % 360;
                }
            }
        }

        // #RRGGBB → derive hue via simple RGB→HSV.
        if (trimmed.StartsWith('#') && trimmed.Length == 7)
        {
            try
            {
                var r = Convert.ToInt32(trimmed.Substring(1, 2), 16) / 255.0;
                var g = Convert.ToInt32(trimmed.Substring(3, 2), 16) / 255.0;
                var b = Convert.ToInt32(trimmed.Substring(5, 2), 16) / 255.0;
                var max = Math.Max(r, Math.Max(g, b));
                var min = Math.Min(r, Math.Min(g, b));
                var delta = max - min;
                if (delta < 0.0001) return 0;
                double h;
                if (max == r) h = ((g - b) / delta) % 6;
                else if (max == g) h = (b - r) / delta + 2;
                else h = (r - g) / delta + 4;
                var hue = (int)Math.Round(h * 60);
                return (hue % 360 + 360) % 360;
            }
            catch { return 165; }
        }

        return 165;
    }

