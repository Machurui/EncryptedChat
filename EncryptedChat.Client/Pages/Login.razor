@page "/login"
@layout EmptyLayout
@inject EncryptedChat.Client.Services.AuthClient Auth
@inject NavigationManager Nav

@using System.ComponentModel.DataAnnotations
@using EncryptedChat.Client.Pages.Components

<div class="app-background"></div>

<div style="min-height: 100vh; display: grid; place-items: center; padding: 24px;">
    <GlassPanel Radius="28" Class="auth-panel login-panel" Style="width: 100%; max-width: 420px;">
        <div style="padding: 34px 36px 8px; text-align: center;">
            <!-- Shield Icon -->
            <div style="width: 56px; height: 56px; margin: 0 auto 16px; border-radius: 16px;
                        background: linear-gradient(135deg, var(--accent), oklch(0.45 0.16 225));
                        display: grid; place-items: center;
                        box-shadow: inset 1px 1px 1px rgba(255,255,255,0.40), 0 12px 36px var(--accent-glow);">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>

            <div style="font-size: 22px; font-weight: 700; color: white; letter-spacing: -0.02em;">
                Welcome back
            </div>
            <div style="font-size: 13px; color: rgba(255,255,255,0.60); margin-top: 6px; line-height: 1.5;">
                Sign in to your end-to-end encrypted workspace.
            </div>
        </div>

        <div style="padding: 20px 36px 28px;">
            <EditForm Model="@loginModel" OnValidSubmit="@HandleLogin" style="display: flex; flex-direction: column; gap: 12px;">
                <DataAnnotationsValidator/>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div style="padding: 10px 12px; background: rgba(220,60,60,0.15); border: 0.5px solid rgba(220,60,60,0.30);
                                border-radius: 10px; font-size: 12px; color: oklch(0.78 0.14 25);">
                        @errorMessage
                    </div>
                }

                <!-- Email Field -->
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75); letter-spacing: 0.01em;">
                        Email
                    </label>
                    <div class="glass-input">
                        <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 006 0v-1a10 10 0 10-3.92 7.94"/>
                        </svg>
                        <InputText @bind-Value="loginModel.Email" type="email" placeholder="you@workspace.app" />
                    </div>
                </div>

                <!-- Password Field -->
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">
                            Password
                        </label>
                        <a href="/forgot-password" class="link-btn" style="font-size: 11.5px;">Forgot?</a>
                    </div>
                    <div class="glass-input">
                        <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                        <InputText @bind-Value="loginModel.Password" type="password" placeholder="••••••••••" />
                    </div>
                </div>

                <!-- Encryption Banner -->
                <div class="encryption-banner" style="margin-top: 4px;">
                    <svg class="encryption-banner-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                    </svg>
                    <div>
                        <div class="encryption-banner-title">Your key will unlock locally</div>
                        <div class="encryption-banner-text">Decryption happens in your browser. We never see your messages.</div>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="glass-btn glass-btn-primary glass-btn-lg" style="margin-top: 6px; width: 100%;" disabled="@isLoading">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                    </svg>
                    @(isLoading ? "Unlocking..." : "Unlock workspace")
                </button>

                <!-- Divider -->
                <div class="divider-with-text">
                    <span>or</span>
                </div>

                <!-- Recovery Button -->
                <button type="button" class="glass-btn" style="width: 100%;" @onclick="() => showRestore = true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                    </svg>
                    Restore from recovery phrase
                </button>

                <!-- Sign Up Link -->
                <div style="text-align: center; font-size: 12px; color: rgba(255,255,255,0.55); margin-top: 6px;">
                    Don't have an account?
                    <NavLink href="/register" class="link-btn" style="font-weight: 600; margin-left: 4px;">
                        Create one
                    </NavLink>
                </div>
            </EditForm>
        </div>
    </GlassPanel>

    <RestoreModal IsOpen="@showRestore" OnClose="() => showRestore = false" />
</div>

<style>
    @@media (max-width: 767px) {
        .login-panel {
            width: 100% !important;
            max-width: none !important;
            min-height: 100vh !important;
            min-height: 100dvh !important;
            border-radius: 0 !important;
            padding: 60px 20px 24px !important;
            justify-content: flex-start !important;
        }
    }
</style>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;
    private bool isLoading;
    private bool showRestore;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await Auth.LoginAsync(loginModel.Email, loginModel.Password);

            if (!result.Success)
            {
                errorMessage = result.ErrorMessage ?? "Login failed. Please try again.";
                return;
            }

            // Auth succeeded — go to /chat unconditionally. The key-bootstrap
            // check (IndexedDB lookup + KeyBootstrapModal) used to run here
            // but any failure in that path silently left the user stuck on
            // the login screen. Moved to /chat's init so login itself never
            // gates on the crypto layer.
            Nav.NavigateTo("/chat", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }


    public class LoginModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }
}
