@page "/register"
@layout EmptyLayout
@inject EncryptedChat.Client.Services.AuthClient Auth
@inject EncryptedChat.Client.Services.Crypto.BootstrapKeyService BootstrapKeys
@inject NavigationManager Nav
@inject IJSRuntime JS

@using System.ComponentModel.DataAnnotations
@using EncryptedChat.Client.Pages.Components

<div class="app-background"></div>

<div style="min-height: 100vh; display: grid; place-items: center; padding: 24px;">
    <GlassPanel Radius="28" Class="auth-panel register-panel" Style="width: 100%; max-width: 420px;">
        <div style="padding: 34px 36px 8px; text-align: center;">
            <!-- Shield Icon -->
            <div style="width: 56px; height: 56px; margin: 0 auto 16px; border-radius: 16px;
                        background: linear-gradient(135deg, var(--accent), oklch(0.45 0.16 225));
                        display: grid; place-items: center;
                        box-shadow: inset 1px 1px 1px rgba(255,255,255,0.40), 0 12px 36px var(--accent-glow);">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>

            <div style="font-size: 22px; font-weight: 700; color: white; letter-spacing: -0.02em;">
                Create your identity
            </div>
            <div style="font-size: 13px; color: rgba(255,255,255,0.60); margin-top: 6px; line-height: 1.5;">
                Your private key never leaves this device.
            </div>
        </div>

        <div style="padding: 20px 36px 28px;">
        @if (signupRecoveryWords == null)
        {
            <EditForm Model="@registerModel" OnValidSubmit="@HandleRegister" OnInvalidSubmit="@HandleInvalidRegister" style="display: flex; flex-direction: column; gap: 12px;">
                <DataAnnotationsValidator/>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div style="padding: 10px 12px; background: rgba(220,60,60,0.15); border: 0.5px solid rgba(220,60,60,0.30);
                                border-radius: 10px; font-size: 12px; color: oklch(0.78 0.14 25);">
                        @errorMessage
                    </div>
                }

                <ValidationSummary style="margin: 0; padding: 8px 12px; background: rgba(220,60,60,0.10); border: 0.5px solid rgba(220,60,60,0.25); border-radius: 8px; font-size: 12px; color: oklch(0.78 0.14 25); list-style: none;" />

                <!-- Handle Field -->
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">
                        Handle
                    </label>
                    <div class="glass-input">
                        <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                        <InputText @bind-Value="registerModel.Handle" placeholder="your_handle" />
                    </div>
                    <div style="font-size:12px;opacity:0.7;margin-top:4px;">
                        Your unique identifier. Letters, numbers, and underscore (3–32 chars). Cannot be changed later.
                    </div>
                </div>

                <!-- Email Field -->
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">
                        Email
                    </label>
                    <div class="glass-input">
                        <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 006 0v-1a10 10 0 10-3.92 7.94"/>
                        </svg>
                        <InputText @bind-Value="registerModel.Email" type="email" placeholder="you@workspace.app" />
                    </div>
                </div>

                <!-- Password Field -->
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">
                        Password
                    </label>
                    <div class="glass-input">
                        <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                        <InputText @bind-Value="registerModel.Password" type="password" placeholder="••••••••••" />
                    </div>
                </div>

                <!-- Confirm Password Field -->
                <div style="display: flex; flex-direction: column; gap: 5px;">
                    <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">
                        Confirm password
                    </label>
                    <div class="glass-input">
                        <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                        </svg>
                        <InputText @bind-Value="registerModel.ConfirmPassword" type="password" placeholder="••••••••••" />
                    </div>
                </div>

                <!-- Encryption Banner -->
                <div class="encryption-banner" style="margin-top: 4px;">
                    <svg class="encryption-banner-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                    </svg>
                    <div>
                        <div class="encryption-banner-title">Your encryption keys will be generated</div>
                        <div class="encryption-banner-text">Save your recovery phrase — losing it means losing access to past messages.</div>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="glass-btn glass-btn-primary glass-btn-lg" style="margin-top: 6px; width: 100%;" disabled="@isLoading">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                    </svg>
                    @(isLoading ? "Creating account..." : "Create account")
                </button>

                <!-- Sign In Link -->
                <div style="text-align: center; font-size: 12px; color: rgba(255,255,255,0.55); margin-top: 6px;">
                    Already have an account?
                    <NavLink href="/login" class="link-btn" style="font-weight: 600; margin-left: 4px;">
                        Sign in
                    </NavLink>
                </div>
            </EditForm>
        }
        else
        {
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div style="font-size: 22px; font-weight: 700; color: white; letter-spacing: -0.02em; text-align: center;">
                    Save your recovery phrase
                </div>

                <div class="encryption-banner" style="border-color: rgba(251,191,36,0.40); background: rgba(251,191,36,0.08);">
                    <svg class="encryption-banner-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="oklch(0.85 0.15 75)" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    <div class="encryption-banner-text">
                        Save this phrase now. We <strong>cannot</strong> show it again. Without it, losing your password means losing your account.
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin: 6px 0;">
                    @for (int i = 0; i < signupRecoveryWords.Count; i++)
                    {
                        var index = i;
                        <div style="padding: 10px 12px; background: rgba(255,255,255,0.05); border: 0.5px solid rgba(255,255,255,0.10); border-radius: 8px; font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 13px; color: white;">
                            <span style="opacity: 0.45; margin-right: 6px;">@(index + 1).</span>@signupRecoveryWords[index]
                        </div>
                    }
                </div>

                @if (recoveryCopied)
                {
                    <div style="font-size: 11.5px; color: oklch(0.78 0.14 165); text-align: center;">Copied to clipboard</div>
                }

                <GlassButton OnClick="CopyRecoveryPhrase" Style="width: 100%;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;">
                        <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                    </svg>
                    Copy to clipboard
                </GlassButton>

                <label style="display: flex; align-items: flex-start; gap: 8px; cursor: pointer; font-size: 12px; color: rgba(255,255,255,0.80);">
                    <input type="checkbox" @bind="signupRecoveryConfirmed" style="margin-top: 2px;" />
                    <span>I've written down my recovery phrase in a safe place.</span>
                </label>

                <GlassButton Primary="true" OnClick="ContinueToLogin" Disabled="@(!signupRecoveryConfirmed)" Style="width: 100%;">
                    Continue to login
                </GlassButton>
            </div>
        }
        </div>
    </GlassPanel>
</div>

<style>
    @@media (max-width: 767px) {
        .register-panel {
            width: 100% !important;
            max-width: none !important;
            min-height: 100vh !important;
            min-height: 100dvh !important;
            border-radius: 0 !important;
            padding: 60px 20px 24px !important;
            justify-content: flex-start !important;
        }
    }
</style>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private bool isLoading;

    // Post-signup recovery view state.
    private IReadOnlyList<string>? signupRecoveryWords;
    private bool signupRecoveryConfirmed;
    private bool recoveryCopied;

    private void HandleInvalidRegister()
    {
        errorMessage = "Please fix the highlighted fields and try again.";
    }

    private async Task HandleRegister()
    {
        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await Auth.RegisterAsync(registerModel.Email, registerModel.Password, registerModel.Handle);

            if (result.Success && result.Value != null)
            {
                // Bootstrap the E2E identity keys before showing the phrase view.
                // The server returned a JWT in the same response so the inline
                // PUT /api/User/me/encryption-keys is authenticated.
                string? userId = ExtractUserIdFromJwt(result.Value.AccessToken);
                if (string.IsNullOrEmpty(userId))
                {
                    errorMessage = "Signup succeeded but couldn't extract user identity from the access token. Log in to retry.";
                    return;
                }

                string phrase = string.Join(' ', result.Value.RecoveryWords);
                bool keyOk = await BootstrapKeys.SignupBootstrapAsync(userId, phrase);
                if (!keyOk)
                {
                    errorMessage = "Signup succeeded but encryption-key upload failed. Log in to retry.";
                    return;
                }

                // Switch to the one-shot recovery-phrase view. The phrase is
                // returned by the server only on this success response and is
                // already used (above) to derive the wrap-key — the user must
                // save it before navigating away.
                signupRecoveryWords = result.Value.RecoveryWords;
                signupRecoveryConfirmed = false;
                recoveryCopied = false;
                return;
            }

            errorMessage = result.ErrorMessage ?? "Registration failed. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CopyRecoveryPhrase()
    {
        if (signupRecoveryWords == null) return;
        var text = string.Join(' ', signupRecoveryWords);
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            recoveryCopied = true;
        }
        catch
        {
            // Silently ignore copy failures (older browsers, denied permission).
        }
    }

    private void ContinueToLogin()
    {
        Nav.NavigateTo("/login");
    }

    // Decodes the JWT body (no signature verification — we just need the sub/nameid
    // claim to identify the user for the key-bootstrap PUT).
    private static string? ExtractUserIdFromJwt(string jwt)
    {
        if (string.IsNullOrEmpty(jwt)) return null;

        var parts = jwt.Split('.');
        if (parts.Length != 3) return null;

        string payloadB64 = parts[1];
        // base64url → base64 + padding
        payloadB64 = payloadB64.Replace('-', '+').Replace('_', '/');
        payloadB64 += new string('=', (4 - payloadB64.Length % 4) % 4);

        try
        {
            byte[] payloadBytes = Convert.FromBase64String(payloadB64);
            using var doc = System.Text.Json.JsonDocument.Parse(payloadBytes);
            var root = doc.RootElement;

            if (root.TryGetProperty("sub", out var sub) && sub.ValueKind == System.Text.Json.JsonValueKind.String)
                return sub.GetString();
            if (root.TryGetProperty("nameid", out var nid) && nid.ValueKind == System.Text.Json.JsonValueKind.String)
                return nid.GetString();
            if (root.TryGetProperty("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier", out var nidLong) && nidLong.ValueKind == System.Text.Json.JsonValueKind.String)
                return nidLong.GetString();
        }
        catch
        {
            // Malformed JWT
        }
        return null;
    }

    public class RegisterModel
    {
        [Required(ErrorMessage = "Handle is required")]
        [MinLength(3, ErrorMessage = "Handle must be at least 3 characters")]
        [MaxLength(32, ErrorMessage = "Handle must be at most 32 characters")]
        [RegularExpression(@"^[a-zA-Z0-9_]+$", ErrorMessage = "Handle can only contain letters, numbers, and underscores")]
        public string Handle { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [MinLength(14, ErrorMessage = "Password must be at least 14 characters")]
        [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).+$",
            ErrorMessage = "Password must contain at least one uppercase letter, lowercase letter, digit, and symbol")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
