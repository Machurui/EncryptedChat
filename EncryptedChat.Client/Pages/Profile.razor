@page "/profile"
@layout EmptyLayout
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using EncryptedChat.Client.Services
@using EncryptedChat.Client.Pages.Components

@inject AuthenticationStateProvider AuthStateProvider
@inject UserClient UserClient
@inject NavigationManager Navigation

<div class="app-background"></div>

<div style="min-height: 100vh; display: grid; place-items: center; padding: 24px;">
    <GlassPanel Radius="28" Class="profile-page-panel" Style="width: 100%; max-width: 440px;">
        <div style="padding: 24px 36px;">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
                <a href="/chat" style="color: rgba(255,255,255,0.60); text-decoration: none; display: flex; align-items: center;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
                    </svg>
                </a>
                <div style="font-size: 20px; font-weight: 700; color: var(--text-primary);">Edit Profile</div>
            </div>

            @if (isLoading)
            {
                <div aria-busy="true" style="display: flex; flex-direction: column; gap: 16px;">
                    <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 8px;">
                        <SkeletonBox Width="80px" Height="80px" BorderRadius="50%" />
                        <SkeletonBox Width="80px" Height="20px" BorderRadius="999px" CssClass="skeleton-mt-4" />
                    </div>
                    <div>
                        <SkeletonBox Width="90px" Height="11px" />
                        <SkeletonBox Width="100%" Height="38px" BorderRadius="12px" CssClass="skeleton-mt-4" />
                    </div>
                    <div>
                        <SkeletonBox Width="80px" Height="11px" />
                        <div style="display: flex; gap: 10px; margin-top: 5px;">
                            <SkeletonBox Width="44px" Height="38px" BorderRadius="10px" />
                            <SkeletonBox Width="100%" Height="38px" BorderRadius="12px" />
                        </div>
                    </div>
                    <div>
                        <SkeletonBox Width="120px" Height="11px" />
                        <SkeletonBox Width="100%" Height="38px" BorderRadius="12px" CssClass="skeleton-mt-4" />
                    </div>
                    <div>
                        <SkeletonBox Width="50px" Height="11px" />
                        <SkeletonBox Width="100%" Height="38px" BorderRadius="12px" CssClass="skeleton-mt-4" />
                    </div>
                    <SkeletonBox Width="100%" Height="44px" BorderRadius="12px" CssClass="skeleton-mt-4" />
                </div>
            }
            else if (profile != null)
            {
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div style="padding: 10px 12px; background: rgba(220,60,60,0.15); border: 0.5px solid rgba(220,60,60,0.30);
                                border-radius: 10px; font-size: 12px; color: oklch(0.78 0.14 25); margin-bottom: 16px;">
                        @errorMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div style="padding: 10px 12px; background: rgba(16,185,129,0.15); border: 0.5px solid rgba(16,185,129,0.30);
                                border-radius: 10px; font-size: 12px; color: oklch(0.78 0.14 165); margin-bottom: 16px;">
                        @successMessage
                    </div>
                }

                <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 24px;">
                    <div style="position: relative; margin-bottom: 12px;">
                        @if (!string.IsNullOrEmpty(profileImageUrl))
                        {
                            <img src="@profileImageUrl" alt="Profile"
                                 style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover;
                                        border: 3px solid @nameColor;" />
                        }
                        else
                        {
                            <div style="width: 80px; height: 80px; border-radius: 50%;
                                        display: grid; place-items: center;
                                        font-size: 28px; font-weight: 700; color: var(--text-primary);
                                        background: linear-gradient(135deg, @nameColor, oklch(0.45 0.16 225));
                                        box-shadow: inset 1px 1px 1px rgba(255,255,255,0.40);">
                                @(name.Length > 0 ? name[0].ToString().ToUpper() : "?")
                            </div>
                        }
                    </div>

                    <div class="glass-chip" style="background: linear-gradient(135deg, rgba(59,130,246,0.3), rgba(147,51,234,0.3));">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                        </svg>
                        Level @profile.Level
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 16px;">
                    <div style="display: flex; flex-direction: column; gap: 5px;">
                        <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">Display name</label>
                        <div class="glass-input">
                            <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                            <input type="text" @bind="name" @bind:event="oninput" maxlength="100" placeholder="Your name" />
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 5px;">
                        <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">Name color</label>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <input type="color" @bind="nameColor" @bind:event="oninput"
                                   style="width: 44px; height: 38px; border-radius: 10px; border: 0.5px solid rgba(255,255,255,0.20);
                                          cursor: pointer; background: transparent;" />
                            <div class="glass-input" style="flex: 1;">
                                <input type="text" @bind="nameColor" @bind:event="oninput" maxlength="7"
                                       placeholder="#FFFFFF" style="text-transform: uppercase;" />
                            </div>
                        </div>
                        <div style="display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap;">
                            @foreach (var color in colorPresets)
                            {
                                <button type="button"
                                        style="width: 28px; height: 28px; border-radius: 50%;
                                               background-color: @color; cursor: pointer;
                                               border: 2px solid @(nameColor.ToUpper() == color.ToUpper() ? "white" : "transparent");
                                               transition: all 0.2s ease; box-shadow: 0 2px 8px rgba(0,0,0,0.2);"
                                        @onclick="() => nameColor = color">
                                </button>
                            }
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 5px;">
                        <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">Profile image URL</label>
                        <div class="glass-input">
                            <svg class="glass-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                            </svg>
                            <input type="url" @bind="profileImageUrl" @bind:event="oninput"
                                   placeholder="https://example.com/image.png" maxlength="500" />
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 5px;">
                        <label style="font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,0.75);">Email</label>
                        <div style="padding: 11px 12px; border-radius: 12px;
                                    background: rgba(255,255,255,0.03); border: 0.5px solid var(--border);
                                    font-size: 14px; color: var(--text-muted);">
                            @profile.Email
                        </div>
                    </div>

                    <button type="button" class="glass-btn glass-btn-primary glass-btn-lg profile-save-btn" style="width: 100%; margin-top: 8px;"
                            @onclick="SaveProfile" disabled="@isSaving">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                            <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
                        </svg>
                        @(isSaving ? "Saving..." : "Save Changes")
                    </button>
                </div>
            }
        </div>
    </GlassPanel>
</div>

<style>
    @@media (max-width: 767px) {
        .profile-page-panel {
            width: 100% !important;
            max-width: none !important;
            min-height: 100vh !important;
            min-height: 100dvh !important;
            border-radius: 0 !important;
            padding: 24px 16px !important;
        }
        .profile-save-btn {
            position: sticky;
            bottom: 0;
            z-index: 5;
        }
    }
</style>

@code {
    private UserClient.UserProfileDTO? profile;
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;

    private string name = string.Empty;
    private string nameColor = "#FFFFFF";
    private string? profileImageUrl;

    private readonly string[] colorPresets =
    {
        "#FFFFFF", "#FF6B6B", "#4ECDC4", "#45B7D1", "#96CEB4",
        "#FFEAA7", "#DDA0DD", "#98D8C8", "#F7DC6F", "#BB8FCE"
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity is null || !user.Identity.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await UserClient.GetProfileAsync();
            if (result.Success && result.Value != null)
            {
                profile = result.Value;
                name = profile.Name;
                nameColor = profile.NameColor;
                profileImageUrl = profile.ProfileImageUrl;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Failed to load profile.";
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProfile()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(name) || name.Length < 2)
        {
            errorMessage = "Name must be at least 2 characters.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(nameColor, @"^#[0-9A-Fa-f]{6}$"))
        {
            errorMessage = "Invalid color format. Use #RRGGBB.";
            return;
        }

        isSaving = true;

        try
        {
            var dto = new UserClient.UserUpdateDTO(
                Name: name.Trim() != profile?.Name ? name.Trim() : null,
                Email: null,
                NameColor: nameColor != profile?.NameColor ? nameColor : null,
                ProfileImageUrl: profileImageUrl?.Trim() != profile?.ProfileImageUrl ? profileImageUrl?.Trim() : null
            );

            if (dto.Name == null && dto.NameColor == null && dto.ProfileImageUrl == null)
            {
                successMessage = "No changes to save.";
                return;
            }

            var result = await UserClient.UpdateProfileAsync(dto);
            if (result.Success && result.Value != null)
            {
                profile = result.Value;
                name = profile.Name;
                nameColor = profile.NameColor;
                profileImageUrl = profile.ProfileImageUrl;
                successMessage = "Profile updated!";
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Failed to update profile.";
            }
        }
        finally
        {
            isSaving = false;
        }
    }
}
