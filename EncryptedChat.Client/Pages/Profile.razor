@page "/Profile"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using EncryptedChat.Client.Services

@inject AuthenticationStateProvider AuthStateProvider
@inject UserClient UserClient
@inject NavigationManager Navigation

<section>
    <div class="relative grid place-items-center px-6 py-10 mx-auto min-h-[60svh] md:min-h-[65svh] lg:min-h-[70svh]">
        <div class="flex flex-col items-center w-full sm:max-w-md md:mt-0">
            <div class="liquid-glass-wrapper rounded-3xl shadow-2xl w-full"
                style="border-radius: 20px; background-color: rgba(255, 255, 255, 0.05); box-shadow: rgba(0, 0, 0, 0.2) 0px 6px 6px, rgba(0, 0, 0, 0.1) 0px 0px 20px;">

                <div class="liquid-glass-effect" aria-hidden="true"></div>
                <div class="liquid-glass-tint" aria-hidden="true"></div>
                <div class="liquid-glass-shine" aria-hidden="true"></div>

                <div class="liquid-glass-content p-6 space-y-4 md:space-y-6 sm:p-8">
                    <h1 class="flex justify-center text-xl font-bold leading-tight tracking-tight text-white md:text-2xl">
                        My Profile
                    </h1>

                    @if (isLoading)
                    {
                        <p class="text-sm text-gray-400 text-center">Loading...</p>
                    }
                    else if (profile != null)
                    {
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <p class="text-sm text-red-400">@errorMessage</p>
                        }

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <p class="text-sm text-green-400">@successMessage</p>
                        }

                        <!-- Profile Picture -->
                        <div class="flex flex-col items-center space-y-3">
                            <div class="relative">
                                @if (!string.IsNullOrEmpty(profileImageUrl))
                                {
                                    <img src="@profileImageUrl" alt="Profile"
                                        class="w-24 h-24 rounded-full object-cover border-2"
                                        style="border-color: @nameColor;" />
                                }
                                else
                                {
                                    <div class="w-24 h-24 rounded-full flex items-center justify-center text-3xl font-bold border-2"
                                        style="background-color: @nameColor; border-color: @nameColor; color: white;">
                                        @(profile.Name.Length > 0 ? profile.Name[0].ToString().ToUpper() : "?")
                                    </div>
                                }
                            </div>

                            <!-- Level Badge -->
                            <div class="px-3 py-1 rounded-full bg-gradient-to-r from-blue-500/50 to-purple-500/50 border border-white/20">
                                <span class="text-sm font-semibold text-white">Level @profile.Level</span>
                            </div>
                        </div>

                        <!-- Preview Name -->
                        <div class="text-center">
                            <span class="text-lg font-semibold" style="color: @nameColor;">@name</span>
                        </div>

                        <!-- Form -->
                        <div class="space-y-4">
                            <!-- Name -->
                            <div>
                                <label class="block text-sm font-medium text-gray-200 mb-1">Name</label>
                                <input type="text"
                                    class="w-full rounded-lg px-3 py-2 bg-black/40 border border-white/10 text-white"
                                    @bind="name" @bind:event="oninput" maxlength="100" />
                            </div>

                            <!-- Name Color -->
                            <div>
                                <label class="block text-sm font-medium text-gray-200 mb-1">Name Color</label>
                                <div class="flex gap-2 items-center">
                                    <input type="color"
                                        class="w-12 h-10 rounded-lg cursor-pointer border border-white/10"
                                        @bind="nameColor" @bind:event="oninput" />
                                    <input type="text"
                                        class="flex-1 rounded-lg px-3 py-2 bg-black/40 border border-white/10 text-white uppercase"
                                        @bind="nameColor" @bind:event="oninput" maxlength="7" placeholder="#FFFFFF" />
                                </div>
                                <!-- Color Presets -->
                                <div class="flex gap-2 mt-2 flex-wrap">
                                    @foreach (var color in colorPresets)
                                    {
                                        <button type="button"
                                            class="w-8 h-8 rounded-full border-2 cursor-pointer transition hover:scale-110"
                                            style="background-color: @color; border-color: @(nameColor == color ? "white" : "transparent");"
                                            @onclick="() => nameColor = color">
                                        </button>
                                    }
                                </div>
                            </div>

                            <!-- Profile Image URL -->
                            <div>
                                <label class="block text-sm font-medium text-gray-200 mb-1">Profile Image URL</label>
                                <input type="url"
                                    class="w-full rounded-lg px-3 py-2 bg-black/40 border border-white/10 text-white text-sm"
                                    @bind="profileImageUrl" @bind:event="oninput"
                                    placeholder="https://example.com/image.png" maxlength="500" />
                            </div>

                            <!-- Email (read-only display) -->
                            <div>
                                <label class="block text-sm font-medium text-gray-200 mb-1">Email</label>
                                <div class="w-full rounded-lg px-3 py-2 bg-black/20 border border-white/5 text-gray-400 text-sm">
                                    @profile.Email
                                </div>
                            </div>

                            <!-- Save Button -->
                            <button type="button"
                                class="glass-button-primary w-full justify-center cursor-pointer"
                                @onclick="SaveProfile" disabled="@isSaving">
                                @(isSaving ? "Saving..." : "Save Changes")
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private UserClient.UserProfileDTO? profile;
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;

    private string name = string.Empty;
    private string nameColor = "#FFFFFF";
    private string? profileImageUrl;

    private readonly string[] colorPresets =
    {
        "#FFFFFF", "#FF6B6B", "#4ECDC4", "#45B7D1", "#96CEB4",
        "#FFEAA7", "#DDA0DD", "#98D8C8", "#F7DC6F", "#BB8FCE"
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity is null || !user.Identity.IsAuthenticated)
        {
            Navigation.NavigateTo("/Login");
            return;
        }

        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await UserClient.GetProfileAsync();
            if (result.Success && result.Value != null)
            {
                profile = result.Value;
                name = profile.Name;
                nameColor = profile.NameColor;
                profileImageUrl = profile.ProfileImageUrl;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Failed to load profile.";
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProfile()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(name) || name.Length < 2)
        {
            errorMessage = "Name must be at least 2 characters.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(nameColor, @"^#[0-9A-Fa-f]{6}$"))
        {
            errorMessage = "Invalid color format. Use #RRGGBB.";
            return;
        }

        isSaving = true;

        try
        {
            var dto = new UserClient.UserUpdateDTO(
                Name: name.Trim() != profile?.Name ? name.Trim() : null,
                Email: null,
                NameColor: nameColor != profile?.NameColor ? nameColor : null,
                ProfileImageUrl: profileImageUrl?.Trim() != profile?.ProfileImageUrl ? profileImageUrl?.Trim() : null
            );

            if (dto.Name == null && dto.NameColor == null && dto.ProfileImageUrl == null)
            {
                successMessage = "No changes to save.";
                return;
            }

            var result = await UserClient.UpdateProfileAsync(dto);
            if (result.Success && result.Value != null)
            {
                profile = result.Value;
                name = profile.Name;
                nameColor = profile.NameColor;
                profileImageUrl = profile.ProfileImageUrl;
                successMessage = "Profile updated successfully!";
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Failed to update profile.";
            }
        }
        finally
        {
            isSaving = false;
        }
    }
}
