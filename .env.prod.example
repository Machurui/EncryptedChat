# Copier en .env.prod sur l'hôte (gitignored). Renseigner avec de vraies valeurs.
# DOMAIN = apex only (ex. chat.exemple.com). Pour servir aussi www.<domaine>,
# ajouter le sous-domaine à l'adresse de site dans le Caddyfile.
DOMAIN=chat.exemple.com
IMAGE_TAG=0.1.0
# Épingler un tag MSSQL précis en prod (évite un upgrade auto du moteur au pull).
MSSQL_TAG=2025-latest
MSSQL_SA_PASSWORD=Un_Mot_De_Passe_Fort1
JWT_KEY=remplacer-par-une-cle-secrete-aleatoire-de-32+-caracteres
JWT_ISSUER=EncryptedChat
JWT_AUDIENCE=EncryptedChat.Client
SENTRY_DSN=
# Optionnel : clé API Giphy pour le picker GIF.
GIPHY_API_KEY=
