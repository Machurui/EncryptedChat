{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "SET_IN_USER_SECRETS_OR_ENV"
  },
  "Jwt": {
    "Issuer": "EncryptedChat",
    "Audience": "EncryptedChat.Client",
    "Key": "SET_IN_USER_SECRETS_OR_ENV_MIN_32_CHARS"
  },
  "FileStorage": {
    "BasePath": "./storage/attachments",
    "MaxFileSizeBytes": 26214400,
    "AllowedExtensions": [
      ".jpg", ".jpeg", ".png", ".gif", ".webp", ".bmp", ".svg",
      ".pdf", ".txt", ".csv", ".md",
      ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".odt", ".ods", ".odp",
      ".zip", ".rar", ".7z", ".tar", ".gz",
      ".mp3", ".wav", ".ogg", ".m4a", ".flac",
      ".mp4", ".webm", ".mov", ".avi", ".mkv",
      ".json", ".xml", ".html", ".css", ".js", ".ts", ".py", ".java", ".cs", ".cpp", ".c", ".h"
    ]
  },
  "Gifs": {
    "TenorApiKey": ""
  }
}
